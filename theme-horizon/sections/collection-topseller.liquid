{%- comment -%}
  sections/collection-topseller.liquid
  Topseller dieser Kategorie - horizontaler Produktstreifen.
  Datenquelle: Collection-Metafeld custom.topseller_products (list.product_reference),
  vorberechnet aus der Admin-API (sortKey BEST_SELLING) per scripts/set-topseller.mjs.
  Grund: /products.json?sort_by ignoriert den Sort und native Sections rendern hier
  serverseitig null, daher ist Vorberechnung die zuverlaessige Quelle.
  Preis-/Badge-Anzeige via snippets/price.liquid (VIP / Angebot, kein Stapeln, kein 0,00).
{%- endcomment -%}

{%- assign cots_items = collection.metafields.custom.topseller_products.value -%}
{%- assign cots_n = section.settings.product_count | default: 6 -%}
{%- assign cots_heading = section.settings.heading | default: 'Topseller dieser Kategorie' -%}

{%- if cots_items != blank and cots_items.size > 0 -%}
<section class="cots" aria-label="{{ cots_heading | escape }}">
  <div class="cots__inner">
    <div class="cots__header">
      <h2 class="cots__heading">{{ cots_heading }}</h2>
      <a class="cots__more" href="{{ collection.url }}?sort_by=best-selling">Alle anzeigen</a>
    </div>
    <ul class="cots__grid">
      {%- for item in cots_items limit: cots_n -%}
        <li class="cots__item">
          <a href="{{ item.url }}" class="cots__link">
            <div class="cots__img-wrap">
              {%- if item.featured_image -%}
                <img class="cots__img" src="{{ item.featured_image | image_url: width: 360 }}" alt="{{ item.title | escape }}" loading="lazy" width="360" height="360">
              {%- else -%}
                <div class="cots__img-ph"></div>
              {%- endif -%}
            </div>
            <div class="cots__meta">
              <span class="cots__vendor">{{ item.vendor }}</span>
              <span class="cots__title">{{ item.title }}</span>
              <div class="cots__price">{% render 'price', product_resource: item %}</div>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>
{%- endif -%}

{% style %}
.cots{padding:1.25rem 0 0;border-bottom:1px solid #e5e5e5;margin-bottom:1.5rem;max-width:100%;}
.cots__inner{max-width:1400px;margin:0 auto;padding:0 1.5rem;box-sizing:border-box;}
.cots__header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:.75rem;gap:.5rem;}
.cots__heading{font-size:.92rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin:0;color:#111;white-space:nowrap;}
.cots__more{font-size:.78rem;color:#486A8F;text-decoration:none;white-space:nowrap;flex-shrink:0;}
.cots__more:hover{text-decoration:underline;}
/* Immer feste, kleine Kachelbreite – UNABHAENGIG von der Produktanzahl. Horizontaler,
   links ausgerichteter Flex-Streifen; bei vielen Produkten intern scrollbar (max-width:100%
   + overflow-x:auto -> nie ueber den Seitenrand). So bleibt die Reihe klein & dezent,
   egal ob 2 oder 8 Produkte gezeigt werden. */
.cots__grid{list-style:none;margin:0 0 1.2rem;padding:0 0 .4rem;display:flex;justify-content:flex-start;gap:.75rem;max-width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;}
.cots__item{flex:0 0 150px;min-width:0;}
@media(max-width:749px){ .cots__item{flex:0 0 140px;} }
.cots__link{display:block;color:inherit;text-decoration:none;}
.cots__img-wrap{position:relative;width:100%;aspect-ratio:1;overflow:hidden;background:#f4f4f4;border-radius:4px;margin-bottom:.45rem;}
.cots__img{width:100%;height:100%;object-fit:contain;display:block;transition:opacity .15s;}
.cots__img-ph{width:100%;height:100%;background:#e8e8e8;}
.cots__link:hover .cots__img{opacity:.85;}
.cots__meta{padding:0 .05rem;}
.cots__vendor{display:block;font-size:.69rem;text-transform:uppercase;letter-spacing:.04em;color:#888;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:.12rem;}
.cots__title{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-size:.8rem;font-weight:600;line-height:1.3;color:#111;margin-bottom:.28rem;}
.cots__price{font-size:.82rem;line-height:1.3;position:relative;min-width:0;max-width:100%;overflow:hidden;}
.cots__price .price{font-weight:700;color:#486A8F;}
.cots__price .compare-at-price{color:#9aa0a6;}
/* price.liquid bringt in der schmalen Kachel ein absolut positioniertes
   .visually-hidden mit, das ohne pos. Vorfahren aus dem Scroll-Container ausbricht
   und die Seite dehnt. -> Bezugsrahmen schaffen + visually-hidden korrekt klippen. */
.cots__price .compare-at-price-container{flex-wrap:wrap;max-width:100%;min-width:0;}
.cots__price .visually-hidden{position:absolute!important;width:1px!important;height:1px!important;margin:-1px!important;padding:0!important;border:0!important;overflow:hidden!important;clip:rect(0,0,0,0)!important;white-space:nowrap!important;}
/* Staffelpreise als 2-Spalten-Raster: 10er steht direkt unter dem 2er (wie auf den Kacheln). */
.cots__price .belag-tiers{display:grid;grid-template-columns:max-content max-content;justify-content:start;column-gap:.5em;row-gap:.15em;}
.cots__price .belag-tier{padding:0;}
.cots__price .belag-tier+.belag-tier{border-inline-start:0;padding-inline-start:0;}
.cots__price .belag-tier:nth-child(2n){border-inline-start:1px solid #ddd;padding-inline-start:.5em;}
{% endstyle %}

{% schema %}
{
  "name": "Topseller Kategorie",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift",
      "default": "Topseller dieser Kategorie"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Anzahl Produkte",
      "min": 4,
      "max": 8,
      "step": 2,
      "default": 6
    }
  ],
  "presets": [
    { "name": "Topseller Kategorie" }
  ]
}
{% endschema %}
