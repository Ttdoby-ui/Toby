{%- comment -%}
  ============================================================================
  Design System · Section: Card Grid (fs-card-grid)
  ----------------------------------------------------------------------------
  EINE wiederverwendbare Karten-Komponente für viele Einsatzzwecke:
  Beratung (Schlägerfinder, Belagfinder …), Community, Events, Academy,
  Guides, Kategorien. Statt vieler Spezial-Sections gibt es genau diese eine
  konfigurierbare Komponente ("keine doppelten Komponenten").

  Jede Karte ist ein Block: Bild ODER Icon, Eyebrow, Titel, Text, Link, Badge.
  Karten mit Link sind vollflächig klickbar (a11y über aria-label).
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent_color | default: '#0a4fa0'
  assign uid = section.id | replace: '_', '' | replace: '-', ''
  assign cols = section.settings.columns_desktop | default: 3
-%}

{%- style -%}
  .fs-cg--{{ uid }} { --fs-cg-accent: {{ accent }}; --fs-cg-cols: {{ cols }}; }
{%- endstyle -%}

<style>
  .fs-cg__inner { max-width: var(--page-width, 1400px); margin-inline: auto; padding-inline: var(--page-margin, 2rem); }
  .fs-cg--bg-light { background: #ffffff; color: #14181c; }
  .fs-cg--bg-grey { background: #f5f5f5; color: #14181c; }
  .fs-cg--bg-anthracite { background: #14181c; color: #ffffff; }

  .fs-cg__head { max-width: 46rem; margin: 0 0 clamp(1.5rem, 4vw, 2.5rem); }
  .fs-cg--center .fs-cg__head { margin-inline: auto; text-align: center; }
  .fs-cg__eyebrow { display:inline-block; font-weight:600; letter-spacing:.12em; text-transform:uppercase; font-size:.8rem; color:var(--fs-cg-accent); margin:0 0 .6rem; }
  .fs-cg__title { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.05; margin: 0; }
  .fs-cg__intro { margin: .9rem 0 0; font-size: 1.05rem; line-height: 1.6; opacity: .8; }

  .fs-cg__grid { display: grid; grid-template-columns: 1fr; gap: clamp(.85rem, 1.8vw, 1.4rem); }
  @media (min-width: 600px) { .fs-cg__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 990px) { .fs-cg__grid { grid-template-columns: repeat(var(--fs-cg-cols, 3), 1fr); } }

  .fs-cg__card {
    position: relative; display: flex; flex-direction: column; overflow: hidden;
    border-radius: 16px; border: 1px solid rgba(128,128,128,.16);
    background: var(--fs-cg-card-bg, #fff); color: inherit; text-decoration: none;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .fs-cg--bg-anthracite .fs-cg__card { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.12); }
  a.fs-cg__card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(8,12,18,.12); border-color: color-mix(in srgb, var(--fs-cg-accent) 50%, transparent); }
  a.fs-cg__card:focus-visible { outline: 3px solid var(--fs-cg-accent); outline-offset: 3px; }

  .fs-cg__media { position: relative; aspect-ratio: 16 / 10; overflow: hidden; background: #11161b; }
  .fs-cg__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s cubic-bezier(.2,.7,.2,1); }
  a.fs-cg__card:hover .fs-cg__media img { transform: scale(1.05); }

  .fs-cg__body { padding: clamp(1rem, 2vw, 1.5rem); display: flex; flex-direction: column; gap: .45rem; flex: 1; }
  .fs-cg__icon { width: 2.6rem; height: 2.6rem; color: var(--fs-cg-accent); margin-bottom: .35rem; }
  .fs-cg__icon svg { width: 100%; height: 100%; }
  .fs-cg__card-eyebrow { font-size:.76rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--fs-cg-accent); }
  .fs-cg__card-title { font-size: 1.25rem; line-height: 1.2; margin: 0; }
  .fs-cg__card-text { margin: .15rem 0 0; font-size: .97rem; line-height: 1.55; opacity: .82; }
  .fs-cg__cta { margin-top: auto; padding-top: .9rem; display: inline-flex; align-items: center; gap: .45rem; font-weight: 600; font-size: .95rem; color: var(--fs-cg-accent); }
  .fs-cg__cta svg { width: 1.05em; height: 1.05em; transition: transform .2s ease; }
  a.fs-cg__card:hover .fs-cg__cta svg { transform: translateX(4px); }

  .fs-cg__badge { position: absolute; top: .9rem; left: .9rem; z-index: 2; font-size:.7rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; padding:.35rem .55rem; border-radius:999px; background: var(--fs-cg-accent); color:#fff; line-height:1; }

  @media (prefers-reduced-motion: reduce) {
    .fs-cg__card, .fs-cg__media img, .fs-cg__cta svg { transition: none; }
    a.fs-cg__card:hover { transform: none; }
    a.fs-cg__card:hover .fs-cg__media img { transform: none; }
  }
</style>

<div
  class="fs-cg fs-cg--{{ uid }} fs-cg--bg-{{ section.settings.background }}{% if section.settings.text_align == 'center' %} fs-cg--center{% endif %}"
  style="padding-block-start: {{ section.settings['padding-block-start'] | default: 56 }}px; padding-block-end: {{ section.settings['padding-block-end'] | default: 56 }}px;"
>
  <div class="fs-cg__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.intro != blank -%}
      <header class="fs-cg__head">
        {%- if section.settings.eyebrow != blank -%}<span class="fs-cg__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="fs-cg__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.intro != blank -%}<div class="fs-cg__intro">{{ section.settings.intro }}</div>{%- endif -%}
      </header>
    {%- endif -%}

    <div class="fs-cg__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign tag = 'div'
          if block.settings.link != blank
            assign tag = 'a'
          endif
        -%}
        <{{ tag }} class="fs-cg__card" {% if tag == 'a' %}href="{{ block.settings.link }}" aria-label="{{ block.settings.title | escape }}"{% endif %} {{ block.shopify_attributes }}>
          {%- if block.settings.badge != blank -%}<span class="fs-cg__badge">{{ block.settings.badge }}</span>{%- endif -%}
          {%- if block.settings.image != blank -%}
            <div class="fs-cg__media">
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 33vw, (min-width: 600px) 50vw, 100vw', widths: '300, 500, 700, 900', alt: block.settings.title | escape }}
            </div>
          {%- endif -%}
          <div class="fs-cg__body">
            {%- if block.settings.image == blank and block.settings.icon != 'none' -%}
              <span class="fs-cg__icon">
                {%- case block.settings.icon -%}
                  {%- when 'compass' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M15.5 8.5l-2 5-5 2 2-5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                  {%- when 'trophy' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 4h10v4a5 5 0 0 1-10 0z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M7 5H4v2a3 3 0 0 0 3 3M17 5h3v2a3 3 0 0 1-3 3M9 18h6M10 18l.5-3h3l.5 3M9 21h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {%- when 'calendar' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  {%- when 'cap' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 4l10 5-10 5L2 9z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M6 11v5c0 1 2.7 2.5 6 2.5s6-1.5 6-2.5v-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  {%- when 'people' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M3 19a6 6 0 0 1 12 0M16 6a3 3 0 0 1 0 6M21 19a6 6 0 0 0-5-5.9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  {%- when 'book' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 5a2 2 0 0 1 2-2h6v16H6a2 2 0 0 0-2 2zM20 5a2 2 0 0 0-2-2h-6v16h6a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                  {%- when 'play' -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M10 8.5l5 3.5-5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                  {%- else -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M8 12l2.5 2.5L16 9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- endcase -%}
              </span>
            {%- endif -%}
            {%- if block.settings.eyebrow != blank -%}<span class="fs-cg__card-eyebrow">{{ block.settings.eyebrow }}</span>{%- endif -%}
            {%- if block.settings.title != blank -%}<h3 class="fs-cg__card-title">{{ block.settings.title }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<p class="fs-cg__card-text">{{ block.settings.text }}</p>{%- endif -%}
            {%- if block.settings.cta_label != blank and tag == 'a' -%}
              <span class="fs-cg__cta">{{ block.settings.cta_label }}
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            {%- endif -%}
          </div>
        </{{ tag }}>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Card Grid",
  "tag": "section",
  "class": "section fs-section",
  "settings": [
    { "type": "header", "content": "Kopfbereich" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Beratung" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Finde dein perfektes Material" },
    { "type": "richtext", "id": "intro", "label": "Einleitungstext" },
    { "type": "select", "id": "text_align", "label": "Ausrichtung Kopfbereich", "options": [ { "value": "left", "label": "Links" }, { "value": "center", "label": "Zentriert" } ], "default": "left" },
    { "type": "header", "content": "Layout & Farben" },
    { "type": "range", "id": "columns_desktop", "label": "Spalten (Desktop)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "select", "id": "background", "label": "Hintergrund", "options": [ { "value": "light", "label": "Weiß" }, { "value": "grey", "label": "Hellgrau" }, { "value": "anthracite", "label": "Anthrazit" } ], "default": "light" },
    { "type": "color", "id": "accent_color", "label": "Akzentfarbe (Futurespin-Blau)", "default": "#0a4fa0" },
    { "type": "header", "content": "Abstand" },
    { "type": "range", "id": "padding-block-start", "label": "Oben", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "Unten", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Karte",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild (optional)" },
        {
          "type": "select", "id": "icon", "label": "Icon (falls kein Bild)",
          "options": [
            { "value": "none", "label": "Keins" },
            { "value": "compass", "label": "Finder / Beratung" },
            { "value": "book", "label": "Guide" },
            { "value": "play", "label": "Video" },
            { "value": "trophy", "label": "Turnier" },
            { "value": "calendar", "label": "Event" },
            { "value": "cap", "label": "Academy" },
            { "value": "people", "label": "Community / Verein" }
          ],
          "default": "compass"
        },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow (optional)" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Schlägerfinder" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "In wenigen Schritten zum passenden Schläger." },
        { "type": "text", "id": "cta_label", "label": "CTA-Text", "default": "Mehr erfahren" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "badge", "label": "Badge (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Card Grid",
      "blocks": [
        { "type": "card", "settings": { "icon": "compass", "title": "Schlägerfinder", "text": "In wenigen Schritten zum passenden Schläger." } },
        { "type": "card", "settings": { "icon": "compass", "title": "Belagfinder", "text": "Den richtigen Belag für deinen Spielstil." } },
        { "type": "card", "settings": { "icon": "book", "title": "Anfänger-Guides", "text": "Wissen & Tipps für deinen Einstieg." } }
      ]
    }
  ]
}
{% endschema %}
