{%- comment -%}
  ============================================================================
  Design System · Section: Marken-/Logo-Grid (fs-brand-grid)
  ----------------------------------------------------------------------------
  Ruhiges Logo-Raster für Marken/Partner. Jede Marke ist ein Block (Logo,
  Name, Link). Optional Graustufen-Logos, die beim Hover in Farbe erscheinen.
  Wiederverwendbar für Tischtennis-, Padel- und Pickleball-Marken.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent_color | default: '#486A8F'
  assign uid = section.id | replace: '_', '' | replace: '-', ''
  assign cols = section.settings.columns_desktop | default: 5
-%}

{%- style -%}
  .fs-brands--{{ uid }} { --fs-b-accent: {{ accent }}; --fs-b-cols: {{ cols }}; }
{%- endstyle -%}

<style>
  .fs-brands__inner { max-width: var(--page-width, 1400px); margin-inline: auto; padding-inline: var(--page-margin, 2rem); }
  .fs-brands--bg-light { background: #ffffff; color: #14181c; }
  .fs-brands--bg-grey { background: #f5f5f5; color: #14181c; }
  .fs-brands--bg-anthracite { background: #14181c; color: #ffffff; }

  .fs-brands__head { text-align: center; max-width: 46rem; margin: 0 auto clamp(1.5rem, 4vw, 2.5rem); }
  .fs-brands__eyebrow { display:inline-block; font-weight:600; letter-spacing:.12em; text-transform:uppercase; font-size:.8rem; color:var(--fs-b-accent); margin:0 0 .6rem; }
  .fs-brands__title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); line-height: 1.05; margin: 0; }
  .fs-brands__intro { margin: .9rem 0 0; font-size: 1.02rem; line-height: 1.6; opacity: .8; }

  .fs-brands__grid {
    display: grid; gap: clamp(.5rem, 1.5vw, 1rem);
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 600px) { .fs-brands__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 990px) { .fs-brands__grid { grid-template-columns: repeat(var(--fs-b-cols, 5), 1fr); } }

  .fs-brands__item {
    display: flex; align-items: center; justify-content: center;
    aspect-ratio: 3 / 2; padding: clamp(.75rem, 2vw, 1.5rem);
    border-radius: 12px; border: 1px solid rgba(128,128,128,.14);
    background: var(--fs-b-item-bg, rgba(255,255,255,.5));
    text-decoration: none;
  }
  .fs-brands--bg-anthracite .fs-brands__item { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.1); }
  .fs-brands__item img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
  .fs-brands--grayscale .fs-brands__item img { filter: grayscale(1); opacity: .7; transition: filter .2s ease, opacity .2s ease; }
  .fs-brands--grayscale a.fs-brands__item:hover img { filter: grayscale(0); opacity: 1; }
  .fs-brands__name { font-weight: 600; font-size: 1rem; text-align: center; opacity: .85; }
  a.fs-brands__item:focus-visible { outline: 3px solid var(--fs-b-accent); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) { .fs-brands--grayscale .fs-brands__item img { transition: none; } }
</style>

<div
  class="fs-brands fs-brands--{{ uid }} fs-brands--bg-{{ section.settings.background }}{% if section.settings.grayscale %} fs-brands--grayscale{% endif %}"
  style="padding-block-start: {{ section.settings['padding-block-start'] | default: 56 }}px; padding-block-end: {{ section.settings['padding-block-end'] | default: 56 }}px;"
>
  <div class="fs-brands__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.intro != blank -%}
      <header class="fs-brands__head">
        {%- if section.settings.eyebrow != blank -%}<span class="fs-brands__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="fs-brands__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.intro != blank -%}<div class="fs-brands__intro">{{ section.settings.intro }}</div>{%- endif -%}
      </header>
    {%- endif -%}

    <div class="fs-brands__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign tag = 'div'
          if block.settings.link != blank
            assign tag = 'a'
          endif
        -%}
        <{{ tag }} class="fs-brands__item" {% if tag == 'a' %}href="{{ block.settings.link }}" aria-label="{{ block.settings.name | escape }}"{% endif %} {{ block.shopify_attributes }}>
          {%- if block.settings.logo != blank -%}
            {{ block.settings.logo | image_url: width: 320 | image_tag: loading: 'lazy', widths: '120, 200, 320', alt: block.settings.name | escape }}
          {%- elsif block.settings.name != blank -%}
            <span class="fs-brands__name">{{ block.settings.name }}</span>
          {%- endif -%}
        </{{ tag }}>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Marken-Grid",
  "tag": "section",
  "class": "section fs-section",
  "settings": [
    { "type": "header", "content": "Kopfbereich" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Marken" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Top-Marken bei Futurespin" },
    { "type": "richtext", "id": "intro", "label": "Einleitungstext" },
    { "type": "header", "content": "Layout & Farben" },
    { "type": "range", "id": "columns_desktop", "label": "Spalten (Desktop)", "min": 3, "max": 6, "step": 1, "default": 5 },
    { "type": "checkbox", "id": "grayscale", "label": "Logos in Graustufen (Farbe bei Hover)", "default": true },
    {
      "type": "select", "id": "background", "label": "Hintergrund",
      "options": [
        { "value": "light", "label": "Weiß" },
        { "value": "grey", "label": "Hellgrau" },
        { "value": "anthracite", "label": "Anthrazit" }
      ],
      "default": "light"
    },
    { "type": "color", "id": "accent_color", "label": "Akzentfarbe (Futurespin-Blau)", "default": "#486A8F" },
    { "type": "header", "content": "Abstand" },
    { "type": "range", "id": "padding-block-start", "label": "Oben", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "Unten", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marke",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Name (alt-Text / Fallback)", "default": "Marke" },
        { "type": "url", "id": "link", "label": "Link (Marken-Collection)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marken-Grid",
      "blocks": [
        { "type": "brand", "settings": { "name": "andro" } },
        { "type": "brand", "settings": { "name": "DONIC" } },
        { "type": "brand", "settings": { "name": "VICTAS" } },
        { "type": "brand", "settings": { "name": "TIBHAR" } },
        { "type": "brand", "settings": { "name": "Mizuno" } }
      ]
    }
  ]
}
{% endschema %}
