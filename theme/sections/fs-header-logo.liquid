{%- comment -%}
  ============================================================================
  Design System · Section: Header-Logo-Tausch (fs-header-logo)
  ----------------------------------------------------------------------------
  Tauscht das globale Header-Logo pro Sportwelt gegen ein sport-spezifisches
  Logo aus. Läuft in der Header-Gruppe, rendert selbst NICHTS Sichtbares –
  nur Daten + ein kleines Skript, das das Core-Logo (.header-logo__image)
  ersetzt und mit einem dezenten dunklen „Badge“ hinterlegt (damit die für
  dunklen Hintergrund gestalteten Logos auf dem hellen Header lesbar bleiben).

  Erkennung wie bei Switcher/Kategorie-Leiste:
    1. Welt-Seite (/pages/welt-*) oder
    2. eine aktive Unterkategorie der Sportart (Kollektionsseite).
  Persistenz: liest denselben localStorage-Key wie der Sportart-Umschalter,
  damit das Logo auch auf neutralen Seiten zur gewählten Sportart passt.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign uid = section.id | replace: '_', '' | replace: '-', ''
  assign path = request.path
  assign menu = linklists[section.settings.menu]

  comment
    Robustheit: Falls das konfigurierte Menü die Sportwelten nicht enthält
    (z. B. weil der Theme-Editor das Menü-Setting normalisiert/entfernt hat),
    automatisch auf die Futurespin-Hauptnavigation ausweichen.
  endcomment
  assign has_worlds = false
  for link in menu.links
    for block in section.blocks
      if block.settings.link != blank and block.settings.link == link.url
        assign has_worlds = true
      endif
    endfor
  endfor
  unless has_worlds
    assign menu = linklists['futurespin-hauptnav']
  endunless

  assign current_world = null
  for link in menu.links
    if link.links.size > 0 and link.url != '/' and link.url != blank
      if path == link.url or path contains link.url
        assign current_world = link.url
      endif
    endif
  endfor
  unless current_world
    for link in menu.links
      if link.links.size > 0
        for sub in link.links
          if sub.url != blank and sub.url != '/'
            assign sub_prefix = sub.url | append: '/'
            if path == sub.url or path contains sub_prefix
              assign current_world = link.url
            endif
          endif
        endfor
      endif
    endfor
  endunless

  assign current_sport_link = ''
  assign current_accent = ''
  for block in section.blocks
    if current_world and block.settings.link == current_world
      assign current_sport_link = block.settings.link
      assign current_accent = block.settings.accent | default: '#486A8F'
    endif
  endfor

  assign badge_color = section.settings.badge_color | default: '#000000'
  assign badge_radius = section.settings.badge_radius | default: 12
  assign h_mobile = section.settings.logo_height_mobile | default: 26
  assign h_desktop = section.settings.logo_height | default: 38
-%}

<style>
  {%- if section.settings.use_badge -%}
  .header-logo.fs-hl-swapped {
    background: {{ badge_color }};
    border-radius: {{ badge_radius }}px;
    padding: 5px 11px;
  }
  {%- endif -%}
  .header-logo.fs-hl-swapped .header-logo__image {
    width: auto !important;
    height: {{ h_mobile }}px !important;
    max-width: 60vw;
    object-fit: contain;
  }
  @media screen and (min-width: 750px) {
    .header-logo.fs-hl-swapped .header-logo__image { height: {{ h_desktop }}px !important; max-width: 320px; }
  }

  /* Sport-Farbdesign: Ankündigungsbanner & Warenkorb-Bubble folgen der Sportart.
     Fallback = Marken-Blau, wenn keine Sportart aktiv ist. */
  .fs-ticker { --ticker-bg: var(--fs-sport-accent, #486A8F) !important; }
  #header-component, .header, .header__row, .header__inline-menu {
    --cart-bubble-background: var(--fs-sport-accent, #486A8F) !important;
    --cart-bubble-text: #ffffff !important;
  }

  /* Header-Lupe ausblenden (mobil & Desktop) – das Suchfeld ersetzt sie.
     Die Suche im Menü-Drawer (--hidden-on-menu) bleibt erhalten. */
  .search-action:not(.search-action--hidden-on-menu) { display: none !important; }
  {%- if current_sport_link != '' and current_accent != blank -%}
  :root { --fs-sport-accent: {{ current_accent }}; }
  {%- endif -%}
</style>

<div id="fs-hl-{{ uid }}" data-fs-headerlogo data-current-link="{{ current_sport_link }}" hidden>
  {%- for block in section.blocks -%}
    {%- assign logo_url = block.settings.image | image_url: width: 700 -%}
    {%- if block.settings.link != blank and logo_url != blank -%}
      <span data-link="{{ block.settings.link }}" data-logo="{{ logo_url }}" data-alt="{{ block.settings.alt | default: block.settings.link | escape }}" data-accent="{{ block.settings.accent | default: '#486A8F' }}"></span>
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  (function () {
    var root = document.getElementById('fs-hl-{{ uid }}');
    if (!root) return;
    var KEY = 'fs-sport-world';
    var map = {};
    root.querySelectorAll('[data-link]').forEach(function (s) {
      var l = s.getAttribute('data-link');
      if (l) { map[l] = { logo: s.getAttribute('data-logo'), alt: s.getAttribute('data-alt'), accent: s.getAttribute('data-accent') }; }
    });

    function apply(link) {
      if (!link || !map[link]) return false;
      // Sport-Akzentfarbe global setzen (auch auf neutralen Seiten wie Warenkorb/Suche).
      if (map[link].accent) {
        document.documentElement.style.setProperty('--fs-sport-accent', map[link].accent);
      }
      var a = document.querySelector('.header-logo');
      if (a) {
        // Logo verlinkt auf die aktuelle Sportwelt statt auf die Startseite.
        a.setAttribute('href', link);
        var img = a.querySelector('.header-logo__image');
        if (img) {
          img.setAttribute('src', map[link].logo);
          img.removeAttribute('srcset');
          img.removeAttribute('width');
          if (map[link].alt) { img.setAttribute('alt', map[link].alt); }
          a.classList.add('fs-hl-swapped');
        }
      }
      return true;
    }

    var serverLink = root.getAttribute('data-current-link') || '';
    if (serverLink) {
      apply(serverLink);
    } else {
      // Neutrale Seite: zuletzt gewählte Sportart (vom Umschalter gemerkt) übernehmen.
      var raw = null;
      try { raw = localStorage.getItem(KEY); } catch (e) {}
      if (raw) {
        try { var s = JSON.parse(raw); if (s && s.link) { apply(s.link); } } catch (e) {}
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Header-Logo-Tausch",
  "tag": "section",
  "class": "fs-section fs-header-logo",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menü (zur Sport-Erkennung)", "default": "main-menu" },
    { "type": "header", "content": "Darstellung" },
    { "type": "checkbox", "id": "use_badge", "label": "Dunkles Badge hinterlegen", "info": "Nur nötig für Logos mit dunklem/transparentem Hintergrund. Bei Logos mit weißem Hintergrund ausgeschaltet lassen.", "default": false },
    { "type": "color", "id": "badge_color", "label": "Badge-Hintergrund", "default": "#000000" },
    { "type": "range", "id": "badge_radius", "label": "Badge-Rundung", "min": 0, "max": 28, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "logo_height_mobile", "label": "Logo-Höhe (mobil)", "min": 16, "max": 96, "step": 2, "unit": "px", "default": 70 },
    { "type": "range", "id": "logo_height", "label": "Logo-Höhe (Desktop)", "min": 20, "max": 120, "step": 2, "unit": "px", "default": 90 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Sport-Logo",
      "settings": [
        { "type": "url", "id": "link", "label": "Link zur Welt-Seite" },
        { "type": "image_picker", "id": "image", "label": "Logo" },
        { "type": "text", "id": "alt", "label": "Alternativtext" },
        { "type": "color", "id": "accent", "label": "Akzentfarbe (Sportwelt)", "default": "#486A8F" }
      ]
    }
  ],
  "presets": [ { "name": "Header-Logo-Tausch" } ]
}
{% endschema %}
