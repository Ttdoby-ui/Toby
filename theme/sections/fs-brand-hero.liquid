{%- comment -%}
  ============================================================================
  Design System · Section: Brand Hero (fs-brand-hero)
  ----------------------------------------------------------------------------
  Großer, emotionaler Marken-Hero für Startseite und Sportwelten-Landingpages.
  Bild ODER Video als Hintergrund, ruhige Fläche mit klarer Typo-Hierarchie,
  bis zu zwei CTAs. Voll über den Customizer konfigurierbar.

  Design-System-Konventionen (siehe theme/DESIGN-SYSTEM.md):
  - Prefix .fs-  · scoped <style> · Akzentfarbe als Setting (Futurespin-Blau)
  - Standard-OS-2.0-Section (theme-portabel, keine theme-spezifischen Snippets)
  - Performance: responsive Bilder, Video lazy, prefers-reduced-motion
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent_color | default: '#0a4fa0'
  assign uid = section.id | replace: '_', '' | replace: '-', ''
  assign overlay = section.settings.overlay_opacity | default: 40 | divided_by: 100.0
-%}

{%- style -%}
  .fs-hero--{{ uid }} { --fs-hero-accent: {{ accent }}; --fs-hero-overlay: {{ overlay }}; }
{%- endstyle -%}

<style>
  .fs-hero { position: relative; isolation: isolate; overflow: hidden; display: grid; }
  .fs-hero--full   { min-height: 92svh; }
  .fs-hero--large  { min-height: 72svh; }
  .fs-hero--medium { min-height: 56svh; }
  .fs-hero--small  { min-height: 40svh; }

  .fs-hero__media, .fs-hero__media img, .fs-hero__media video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2;
  }
  .fs-hero__media--empty { background: linear-gradient(135deg, color-mix(in srgb, var(--fs-hero-accent) 80%, #000) 0%, #0c1117 70%); z-index: -2; }
  .fs-hero__overlay { position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(180deg, rgba(8,12,18,calc(var(--fs-hero-overlay) * .5)) 0%, rgba(8,12,18,var(--fs-hero-overlay)) 100%); }

  .fs-hero__inner {
    width: 100%; max-width: var(--page-width, 1400px); margin-inline: auto;
    padding: clamp(2rem, 6vw, 5rem) var(--page-margin, 2rem);
    display: flex; flex-direction: column; gap: 1.1rem;
    justify-content: var(--fs-hero-justify, center);
  }
  .fs-hero--left   .fs-hero__content { align-items: flex-start; text-align: left; }
  .fs-hero--center .fs-hero__content { align-items: center; text-align: center; margin-inline: auto; }
  .fs-hero__content { display: flex; flex-direction: column; gap: 1.1rem; max-width: 40rem; }

  .fs-hero--light { color: #fff; }
  .fs-hero--dark  { color: #14181c; }

  .fs-hero__eyebrow {
    font-weight: 600; letter-spacing: .14em; text-transform: uppercase; font-size: .82rem;
    color: var(--fs-hero-accent);
  }
  .fs-hero--light .fs-hero__eyebrow { color: #fff; opacity: .9; }
  .fs-hero__title { font-size: clamp(2.2rem, 6vw, 4.2rem); line-height: 1.02; margin: 0; letter-spacing: -.02em; }
  .fs-hero__text { font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.55; margin: 0; opacity: .92; max-width: 36ch; }
  .fs-hero--center .fs-hero__text { max-width: 52ch; }

  .fs-hero__ctas { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: .5rem; }
  .fs-hero__btn {
    display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
    padding: .85rem 1.5rem; border-radius: 999px; font-weight: 600; font-size: 1rem;
    text-decoration: none; line-height: 1; border: 1.5px solid transparent;
    transition: transform .15s ease, filter .15s ease, background .15s ease, color .15s ease;
  }
  .fs-hero__btn--primary { background: var(--fs-hero-accent); color: #fff; border-color: var(--fs-hero-accent); }
  .fs-hero__btn--primary:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .fs-hero__btn--secondary { background: transparent; color: currentColor; border-color: currentColor; }
  .fs-hero__btn--secondary:hover { transform: translateY(-1px); }
  .fs-hero__btn:focus-visible { outline: 3px solid var(--fs-hero-accent); outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    .fs-hero__btn { transition: none; }
  }
</style>

<div class="fs-hero fs-hero--{{ uid }} fs-hero--{{ section.settings.height }} fs-hero--{{ section.settings.text_align }} fs-hero--{{ section.settings.text_color }}">
  <div class="fs-hero__media{% if section.settings.image == blank and section.settings.video == blank and section.settings.video_url == blank %} fs-hero__media--empty{% endif %}">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: image_size: '1600x', loop: true, autoplay: true, muted: true, controls: false, playsinline: true }}
    {%- elsif section.settings.video_url != blank -%}
      <video autoplay muted loop playsinline preload="none"
        poster="{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1600 }}{% endif %}">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '600, 900, 1200, 1600, 2000, 2600',
          alt: section.settings.heading | escape
      }}
    {%- endif -%}
  </div>
  <div class="fs-hero__overlay"></div>

  <div class="fs-hero__inner">
    <div class="fs-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="fs-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="fs-hero__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="fs-hero__text">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
        <div class="fs-hero__ctas">
          {%- if section.settings.cta1_label != blank -%}
            <a class="fs-hero__btn fs-hero__btn--primary" href="{{ section.settings.cta1_link | default: '#' }}">{{ section.settings.cta1_label }}</a>
          {%- endif -%}
          {%- if section.settings.cta2_label != blank -%}
            <a class="fs-hero__btn fs-hero__btn--secondary" href="{{ section.settings.cta2_link | default: '#' }}">{{ section.settings.cta2_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand Hero",
  "tag": "section",
  "class": "section fs-section fs-section--full",
  "settings": [
    { "type": "header", "content": "Inhalt" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Home of Racket Sports" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "Spiel. Leidenschaft. Community." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Von Tischtennis bis Padel und Pickleball – entdecke Equipment, Courts, Stores und Events von Futurespin.</p>" },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "cta1_label", "label": "Button 1 – Text", "default": "Jetzt entdecken" },
    { "type": "url", "id": "cta1_link", "label": "Button 1 – Link" },
    { "type": "text", "id": "cta2_label", "label": "Button 2 – Text", "default": "Court buchen" },
    { "type": "url", "id": "cta2_link", "label": "Button 2 – Link" },
    { "type": "header", "content": "Hintergrund" },
    { "type": "image_picker", "id": "image", "label": "Bild" },
    { "type": "video", "id": "video", "label": "Video (Shopify-gehostet)" },
    { "type": "url", "id": "video_url", "label": "Video-URL (.mp4, extern)", "info": "Alternative zum Shopify-Video." },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay-Stärke", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 40 },
    { "type": "header", "content": "Layout & Farben" },
    {
      "type": "select", "id": "height", "label": "Höhe",
      "options": [
        { "value": "small", "label": "Klein" },
        { "value": "medium", "label": "Mittel" },
        { "value": "large", "label": "Groß" },
        { "value": "full", "label": "Vollbild" }
      ],
      "default": "large"
    },
    {
      "type": "select", "id": "text_align", "label": "Ausrichtung",
      "options": [ { "value": "left", "label": "Links" }, { "value": "center", "label": "Zentriert" } ],
      "default": "left"
    },
    {
      "type": "select", "id": "text_color", "label": "Textfarbe",
      "options": [ { "value": "light", "label": "Hell (auf dunklem Bild)" }, { "value": "dark", "label": "Dunkel (auf hellem Bild)" } ],
      "default": "light"
    },
    { "type": "color", "id": "accent_color", "label": "Akzentfarbe (Futurespin-Blau)", "default": "#0a4fa0" }
  ],
  "presets": [ { "name": "Brand Hero" } ]
}
{% endschema %}
