{%- comment -%}
  ============================================================================
  Design System · Section: Collection-Strip (fs-collection-strip)
  ----------------------------------------------------------------------------
  Schlanker Produkt-Streifen aus EINER Collection – je Sportwelt das eigene
  Sortiment (z. B. Padel, Pickleball, Bestseller). Bewusst leichtgewichtig
  (Bild, Titel, Preis, Link); für volle Produktkarten mit Quick-Add kann
  alternativ Horizons product-list genutzt werden.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent_color | default: '#486A8F'
  assign uid = section.id | replace: '_', '' | replace: '-', ''
  assign cols = section.settings.columns_desktop | default: 4
  assign limit = section.settings.max_products | default: 8
  assign coll = collections[section.settings.collection]
-%}

{%- style -%}
  .fs-strip--{{ uid }} { --fs-strip-accent: var(--fs-sport-accent, {{ accent }}); --fs-strip-cols: {{ cols }}; }
{%- endstyle -%}

<style>
  .fs-strip__inner { max-width: var(--page-width, 1400px); margin-inline: auto; padding-inline: var(--page-margin, 2rem); }
  .fs-strip--bg-light { background: #ffffff; color: #14181c; }
  .fs-strip--bg-grey { background: #f5f5f5; color: #14181c; }
  .fs-strip--bg-anthracite { background: #14181c; color: #ffffff; }

  .fs-strip__head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin: 0 0 clamp(1.25rem, 3vw, 2rem); }
  .fs-strip__titles { display: flex; flex-direction: column; gap: .3rem; }
  .fs-strip__eyebrow { font-weight:600; letter-spacing:.12em; text-transform:uppercase; font-size:.8rem; color:var(--fs-strip-accent); }
  .fs-strip--bg-anthracite .fs-strip__eyebrow { color: color-mix(in srgb, var(--fs-strip-accent) 70%, #fff); }
  .fs-strip__title { font-size: clamp(1.5rem, 3vw, 2.2rem); line-height: 1.05; margin: 0; }
  .fs-strip__viewall { font-weight: 600; font-size: .95rem; text-decoration: none; color: var(--fs-strip-accent); white-space: nowrap; }
  .fs-strip--bg-anthracite .fs-strip__viewall { color: color-mix(in srgb, var(--fs-strip-accent) 70%, #fff); }
  .fs-strip__viewall:hover { text-decoration: underline; text-underline-offset: 3px; }

  .fs-strip__grid {
    display: grid; grid-auto-flow: column; grid-auto-columns: 60%;
    gap: clamp(.75rem, 1.5vw, 1.1rem); overflow-x: auto; scroll-snap-type: x mandatory;
    padding-bottom: .5rem;
  }
  @media (min-width: 750px) {
    .fs-strip__grid { grid-auto-flow: row; grid-template-columns: repeat(var(--fs-strip-cols, 4), 1fr); grid-auto-columns: auto; overflow: visible; }
  }
  .fs-strip__card { scroll-snap-align: start; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: .55rem; }
  .fs-strip__media { position: relative; aspect-ratio: 1 / 1; border-radius: 12px; overflow: hidden; background: #eef1ea; }
  .fs-strip--bg-anthracite .fs-strip__media { background: rgba(255,255,255,.05); }
  .fs-strip__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s cubic-bezier(.2,.7,.2,1); }
  .fs-strip__card:hover .fs-strip__media img { transform: scale(1.05); }
  .fs-strip__badge { position: absolute; top: .6rem; left: .6rem; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; padding: .28rem .5rem; border-radius: 999px; background: var(--fs-strip-accent); color: #fff; line-height: 1; }
  .fs-strip__name { font-size: .98rem; line-height: 1.3; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .fs-strip__price { font-weight: 600; font-size: .98rem; }
  .fs-strip__price s { opacity: .55; font-weight: 400; margin-inline-start: .35rem; }
  .fs-strip__card:focus-visible { outline: 3px solid var(--fs-strip-accent); outline-offset: 3px; border-radius: 12px; }
  .fs-strip__empty { opacity: .7; font-size: .95rem; }

  @media (prefers-reduced-motion: reduce) { .fs-strip__media img { transition: none; } }
</style>

<div
  class="fs-strip fs-strip--{{ uid }} fs-strip--bg-{{ section.settings.background }}"
  style="padding-block-start: {{ section.settings['padding-block-start'] | default: 48 }}px; padding-block-end: {{ section.settings['padding-block-end'] | default: 48 }}px;"
>
  <div class="fs-strip__inner">
    <div class="fs-strip__head">
      <div class="fs-strip__titles">
        {%- if section.settings.eyebrow != blank -%}<span class="fs-strip__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="fs-strip__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if coll != blank and section.settings.show_view_all -%}
        <a class="fs-strip__viewall" href="{{ coll.url }}">{{ section.settings.view_all_label | default: 'Alle ansehen' }} →</a>
      {%- endif -%}
    </div>

    {%- if coll != blank and coll.products_count > 0 -%}
      <div class="fs-strip__grid">
        {%- for product in coll.products limit: limit -%}
          <a class="fs-strip__card" href="{{ product.url }}">
            <div class="fs-strip__media">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 60vw', widths: '300, 450, 600', alt: product.title | escape }}
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}<span class="fs-strip__badge">Sale</span>{%- endif -%}
            </div>
            <h3 class="fs-strip__name">{{ product.title }}</h3>
            <div class="fs-strip__price">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- elsif coll != blank -%}
      <p class="fs-strip__empty">In dieser Collection sind noch keine Produkte – hier erscheint automatisch das Sortiment dieser Sportwelt.</p>
    {%- else -%}
      <p class="fs-strip__empty">Bitte im Customizer eine Collection auswählen.</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection-Strip",
  "tag": "section",
  "class": "section fs-section",
  "settings": [
    { "type": "header", "content": "Inhalt" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Beliebt" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "max_products", "label": "Max. Produkte", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "\"Alle ansehen\"-Link zeigen", "default": true },
    { "type": "text", "id": "view_all_label", "label": "Link-Text", "default": "Alle ansehen" },
    { "type": "header", "content": "Layout & Farben" },
    { "type": "range", "id": "columns_desktop", "label": "Spalten (Desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    {
      "type": "select", "id": "background", "label": "Hintergrund",
      "options": [
        { "value": "light", "label": "Weiß" },
        { "value": "grey", "label": "Hellgrau" },
        { "value": "anthracite", "label": "Anthrazit" }
      ],
      "default": "anthracite"
    },
    { "type": "color", "id": "accent_color", "label": "Akzentfarbe (Futurespin-Blau)", "default": "#486A8F" },
    { "type": "header", "content": "Abstand" },
    { "type": "range", "id": "padding-block-start", "label": "Oben", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-block-end", "label": "Unten", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 }
  ],
  "presets": [ { "name": "Collection-Strip" } ]
}
{% endschema %}
