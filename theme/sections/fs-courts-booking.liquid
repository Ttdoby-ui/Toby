{%- comment -%}
  ============================================================================
  Section: Courts buchen (fs-courts-booking)
  ----------------------------------------------------------------------------
  "Spiele bei Futurespin" – Buchung der eigenen Padel-, Pickleball- und
  Tischtennis-Courts. Die Buchung laeuft ueber Playtomic.

  WICHTIG: Es wird NICHTS hart codiert. Jeder Standort ist ein Block, jede
  Buchungs-URL (Padel / Pickleball / Tischtennis / Standort-Seite) ist eine
  konfigurierbare Einstellung. So lassen sich beliebig viele Standorte mit
  jeweils eigenen Playtomic-Links pflegen, ohne den Code zu aendern.

  Ein Sport-Button wird nur dann angezeigt, wenn dafuer eine URL hinterlegt ist.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent_color | default: '#0a4fa0'
  assign uid = section.id | replace: '_', '' | replace: '-', ''
  assign cols = section.settings.columns_desktop | default: 2
-%}

{%- style -%}
  .fs-courts--{{ uid }} { --fs-c-accent: {{ accent }}; --fs-c-cols: {{ cols }}; }
{%- endstyle -%}

<style>
  .fs-courts__inner {
    max-width: var(--page-width, 1400px); margin-inline: auto;
    padding-inline: var(--page-margin, 2rem);
  }
  .fs-courts--bg-light { background: #ffffff; color: #14181c; }
  .fs-courts--bg-grey { background: #f5f5f5; color: #14181c; }
  .fs-courts--bg-anthracite { background: #14181c; color: #ffffff; }

  .fs-courts__head { max-width: 48rem; margin: 0 0 clamp(1.5rem, 4vw, 2.5rem); }
  .fs-courts--center .fs-courts__head { margin-inline: auto; text-align: center; }
  .fs-courts__eyebrow {
    display: inline-block; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
    font-size: .8rem; color: var(--fs-c-accent); margin: 0 0 .6rem;
  }
  .fs-courts__title { font-size: clamp(1.8rem, 4vw, 2.75rem); line-height: 1.05; margin: 0; }
  .fs-courts__intro { margin: .9rem 0 0; font-size: 1.05rem; line-height: 1.6; opacity: .82; }

  .fs-courts__grid {
    display: grid; grid-template-columns: 1fr; gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 750px) {
    .fs-courts__grid { grid-template-columns: repeat(var(--fs-c-cols, 2), 1fr); }
  }

  .fs-courts__card {
    display: flex; flex-direction: column; overflow: hidden;
    border-radius: 16px; border: 1px solid rgba(128,128,128,.18);
    background: var(--fs-c-card-bg, rgba(255,255,255,.6));
  }
  .fs-courts--bg-anthracite .fs-courts__card { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.14); }
  .fs-courts__card-media { position: relative; aspect-ratio: 16 / 9; background: #11161b; overflow: hidden; }
  .fs-courts__card-media img { width: 100%; height: 100%; object-fit: cover; }
  .fs-courts__card-body { padding: clamp(1.1rem, 2.2vw, 1.6rem); display: flex; flex-direction: column; gap: .85rem; }
  .fs-courts__loc-name { font-size: 1.25rem; line-height: 1.2; margin: 0; }
  .fs-courts__loc-addr { margin: 0; font-size: .95rem; line-height: 1.5; opacity: .75; }

  .fs-courts__sports { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: .25rem; }
  .fs-courts__btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .6rem .9rem; border-radius: 999px; font-weight: 600; font-size: .92rem;
    text-decoration: none; line-height: 1; border: 1px solid transparent;
    background: var(--fs-c-accent); color: #fff; transition: filter .15s ease, transform .15s ease;
  }
  .fs-courts__btn:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .fs-courts__btn svg { width: 1.1em; height: 1.1em; }
  .fs-courts__btn--ghost {
    background: transparent; color: inherit; border-color: rgba(128,128,128,.4);
  }
  .fs-courts--bg-anthracite .fs-courts__btn--ghost { border-color: rgba(255,255,255,.35); }
  .fs-courts__btn:focus-visible { outline: 3px solid var(--fs-c-accent); outline-offset: 2px; }

  .fs-courts__note { margin: clamp(1.25rem, 3vw, 2rem) 0 0; font-size: .92rem; opacity: .7; }
  .fs-courts--center .fs-courts__note { text-align: center; }

  @media (prefers-reduced-motion: reduce) {
    .fs-courts__btn { transition: none; }
  }
</style>

<div
  class="fs-courts fs-courts--{{ uid }} fs-courts--bg-{{ section.settings.background }}{% if section.settings.text_align == 'center' %} fs-courts--center{% endif %}"
  style="padding-block-start: {{ section.settings['padding-block-start'] | default: 56 }}px; padding-block-end: {{ section.settings['padding-block-end'] | default: 56 }}px;"
>
  <div class="fs-courts__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.intro != blank -%}
      <header class="fs-courts__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="fs-courts__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="fs-courts__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <div class="fs-courts__intro">{{ section.settings.intro }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="fs-courts__grid">
      {%- for block in section.blocks -%}
        <div class="fs-courts__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="fs-courts__card-media">
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  widths: '400, 600, 800, 1000',
                  alt: block.settings.name | escape
              }}
            </div>
          {%- endif -%}
          <div class="fs-courts__card-body">
            {%- if block.settings.name != blank -%}
              <h3 class="fs-courts__loc-name">{{ block.settings.name }}</h3>
            {%- endif -%}
            {%- if block.settings.address != blank -%}
              <p class="fs-courts__loc-addr">{{ block.settings.address }}</p>
            {%- endif -%}

            <div class="fs-courts__sports">
              {%- if block.settings.padel_url != blank -%}
                <a class="fs-courts__btn" href="{{ block.settings.padel_url }}" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="9" r="6" stroke="currentColor" stroke-width="2"/><path d="M9 14l-3 7M12 15v6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                  {{ block.settings.padel_label | default: 'Padel buchen' }}
                </a>
              {%- endif -%}
              {%- if block.settings.pickleball_url != blank -%}
                <a class="fs-courts__btn" href="{{ block.settings.pickleball_url }}" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="6" stroke="currentColor" stroke-width="2"/><circle cx="10" cy="7" r="1" fill="currentColor"/><circle cx="14" cy="7" r="1" fill="currentColor"/><circle cx="12" cy="10" r="1" fill="currentColor"/><path d="M12 14v7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                  {{ block.settings.pickleball_label | default: 'Pickleball buchen' }}
                </a>
              {%- endif -%}
              {%- if block.settings.tabletennis_url != blank -%}
                <a class="fs-courts__btn" href="{{ block.settings.tabletennis_url }}" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 13h16M6 13c0-4 3-7 7-7s5 2 5 4-2 3-4 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 13l1 7M16 13l-1 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                  {{ block.settings.tabletennis_label | default: 'Tischtennis buchen' }}
                </a>
              {%- endif -%}
              {%- if block.settings.location_url != blank -%}
                <a class="fs-courts__btn fs-courts__btn--ghost" href="{{ block.settings.location_url }}">
                  {{ block.settings.location_label | default: 'Standort ansehen' }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.note != blank -%}
      <p class="fs-courts__note">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Courts buchen",
  "tag": "section",
  "class": "section fs-section",
  "settings": [
    { "type": "header", "content": "Kopfbereich" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Spiele bei Futurespin" },
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Courts buchen" },
    { "type": "richtext", "id": "intro", "label": "Einleitungstext", "default": "<p>Reserviere deinen Padel-, Pickleball- oder Tischtennis-Court an einem unserer Standorte – schnell und bequem ueber Playtomic.</p>" },
    {
      "type": "select", "id": "text_align", "label": "Ausrichtung Kopfbereich",
      "options": [ { "value": "left", "label": "Links" }, { "value": "center", "label": "Zentriert" } ],
      "default": "left"
    },
    { "type": "header", "content": "Layout & Farben" },
    { "type": "range", "id": "columns_desktop", "label": "Spalten (Desktop)", "min": 1, "max": 3, "step": 1, "default": 2 },
    {
      "type": "select", "id": "background", "label": "Hintergrund",
      "options": [
        { "value": "light", "label": "Weiss" },
        { "value": "grey", "label": "Hellgrau" },
        { "value": "anthracite", "label": "Anthrazit" }
      ],
      "default": "grey"
    },
    { "type": "color", "id": "accent_color", "label": "Akzentfarbe (Futurespin-Blau)", "default": "#0a4fa0" },
    { "type": "header", "content": "Hinweis" },
    { "type": "text", "id": "note", "label": "Fusszeilen-Hinweis", "default": "Buchung & Verfuegbarkeit ueber Playtomic. Aenderungen vorbehalten." },
    { "type": "header", "content": "Abstand" },
    { "type": "range", "id": "padding-block-start", "label": "Oben", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "Unten", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Standort",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild (optional)" },
        { "type": "text", "id": "name", "label": "Standort-Name", "default": "Futurespin Adelsdorf" },
        { "type": "text", "id": "address", "label": "Adresse / Untertitel", "default": "Weppersdorf 6a, 91325 Adelsdorf" },
        { "type": "header", "content": "Playtomic-Links (nur ausgefuellte sichtbar)" },
        { "type": "url", "id": "padel_url", "label": "Padel – Buchungs-URL" },
        { "type": "text", "id": "padel_label", "label": "Padel – Button-Text", "default": "Padel buchen" },
        { "type": "url", "id": "pickleball_url", "label": "Pickleball – Buchungs-URL" },
        { "type": "text", "id": "pickleball_label", "label": "Pickleball – Button-Text", "default": "Pickleball buchen" },
        { "type": "url", "id": "tabletennis_url", "label": "Tischtennis – Buchungs-URL" },
        { "type": "text", "id": "tabletennis_label", "label": "Tischtennis – Button-Text", "default": "Tischtennis buchen" },
        { "type": "header", "content": "Standort-Seite" },
        { "type": "url", "id": "location_url", "label": "Standort-Landingpage-URL" },
        { "type": "text", "id": "location_label", "label": "Standort – Button-Text", "default": "Standort ansehen" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Courts buchen",
      "blocks": [
        { "type": "location", "settings": { "name": "Futurespin Adelsdorf", "address": "Weppersdorf 6a, 91325 Adelsdorf" } }
      ]
    }
  ]
}
{% endschema %}
