{%- comment -%}
  ============================================================================
  Section: Trust-Leiste (fs-trust-bar)
  ----------------------------------------------------------------------------
  Ruhige, hochwertige Vertrauens-Leiste: Persoenliche Beratung, eigene Stores,
  eigene Courts, schneller Versand, Click & Collect, sichere Zahlung …

  Jeder Punkt ist ein Block mit waehlbarem Icon (Inline-SVG-Set) ODER eigenem
  Bild, Label und optionalem Untertext. Keine externen Icon-Bibliotheken –
  gut fuer Performance und Core Web Vitals.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign accent = section.settings.accent_color | default: '#0a4fa0'
  assign uid = section.id | replace: '_', '' | replace: '-', ''
-%}

{%- style -%}
  .fs-trust--{{ uid }} { --fs-t-accent: {{ accent }}; }
{%- endstyle -%}

<style>
  .fs-trust__inner {
    max-width: var(--page-width, 1400px); margin-inline: auto;
    padding-inline: var(--page-margin, 2rem);
  }
  .fs-trust--bg-light { background: #ffffff; color: #14181c; }
  .fs-trust--bg-grey { background: #f5f5f5; color: #14181c; }
  .fs-trust--bg-anthracite { background: #14181c; color: #ffffff; }

  .fs-trust__title { text-align: center; font-size: clamp(1.4rem, 3vw, 2rem); margin: 0 0 clamp(1.25rem, 3vw, 2rem); }

  .fs-trust__grid {
    display: grid; gap: clamp(1rem, 2.5vw, 2rem);
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 750px) {
    .fs-trust__grid { grid-template-columns: repeat(var(--fs-t-min, 3), 1fr); }
  }
  @media (min-width: 990px) {
    .fs-trust__grid { grid-template-columns: repeat(var(--fs-t-cols, 6), 1fr); }
  }

  .fs-trust__item {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: .55rem; text-decoration: none; color: inherit;
  }
  .fs-trust__icon {
    width: 2.4rem; height: 2.4rem; color: var(--fs-t-accent);
    display: grid; place-items: center;
  }
  .fs-trust__icon svg { width: 100%; height: 100%; }
  .fs-trust__icon img { width: 100%; height: 100%; object-fit: contain; }
  .fs-trust__label { font-weight: 600; font-size: .98rem; line-height: 1.25; }
  .fs-trust__sub { font-size: .85rem; line-height: 1.4; opacity: .7; }
  a.fs-trust__item:hover .fs-trust__label { text-decoration: underline; text-underline-offset: 3px; }
</style>

<div
  class="fs-trust fs-trust--{{ uid }} fs-trust--bg-{{ section.settings.background }}"
  style="--fs-t-cols: {{ section.blocks.size }}; --fs-t-min: {{ section.blocks.size | at_most: 3 }}; padding-block-start: {{ section.settings['padding-block-start'] | default: 40 }}px; padding-block-end: {{ section.settings['padding-block-end'] | default: 40 }}px;"
>
  <div class="fs-trust__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="fs-trust__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="fs-trust__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign tag = 'div'
          if block.settings.link != blank
            assign tag = 'a'
          endif
        -%}
        <{{ tag }} class="fs-trust__item" {% if tag == 'a' %}href="{{ block.settings.link }}"{% endif %} {{ block.shopify_attributes }}>
          <span class="fs-trust__icon">
            {%- if block.settings.custom_icon != blank -%}
              {{ block.settings.custom_icon | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.label | escape, widths: '48, 72, 96' }}
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'advice' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H8l-4 4V6a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M9 9.5a3 3 0 1 1 4 2.8c-.7.3-1 .8-1 1.7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="16.5" r=".6" fill="currentColor"/></svg>
                {%- when 'store' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 9l1-4h14l1 4M4 9v10h16V9M4 9h16M4 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 19v-5h6v5" stroke="currentColor" stroke-width="1.6"/></svg>
                {%- when 'court' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="1.5" stroke="currentColor" stroke-width="1.6"/><path d="M12 5v14M3 12h18M7 5v14M17 5v14" stroke="currentColor" stroke-width="1.2"/></svg>
                {%- when 'shipping' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7h11v8H3zM14 10h4l3 3v2h-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.8" stroke="currentColor" stroke-width="1.6"/><circle cx="17" cy="17" r="1.8" stroke="currentColor" stroke-width="1.6"/></svg>
                {%- when 'collect' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7l8-4 8 4-8 4-8-4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M4 7v8l8 4 8-4V7M12 11v8" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                {%- when 'payment' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="6" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 10h18" stroke="currentColor" stroke-width="1.6"/><path d="M7 14h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                {%- when 'return' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 9a8 8 0 1 1-1.5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M4 4v5h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- when 'expert' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l2.3 4.7 5.2.8-3.8 3.6.9 5.1L12 14.8 7.4 17.2l.9-5.1L4.5 8.5l5.2-.8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- when 'secure' -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M8 12l2.5 2.5L16 9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </span>
          {%- if block.settings.label != blank -%}
            <span class="fs-trust__label">{{ block.settings.label }}</span>
          {%- endif -%}
          {%- if block.settings.sub != blank -%}
            <span class="fs-trust__sub">{{ block.settings.sub }}</span>
          {%- endif -%}
        </{{ tag }}>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust-Leiste",
  "tag": "section",
  "class": "section fs-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Ueberschrift (optional)" },
    {
      "type": "select", "id": "background", "label": "Hintergrund",
      "options": [
        { "value": "light", "label": "Weiss" },
        { "value": "grey", "label": "Hellgrau" },
        { "value": "anthracite", "label": "Anthrazit" }
      ],
      "default": "light"
    },
    { "type": "color", "id": "accent_color", "label": "Icon-Farbe (Futurespin-Blau)", "default": "#0a4fa0" },
    { "type": "header", "content": "Abstand" },
    { "type": "range", "id": "padding-block-start", "label": "Oben", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding-block-end", "label": "Unten", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Vorteil",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "advice", "label": "Beratung (Sprechblase)" },
            { "value": "store", "label": "Store" },
            { "value": "court", "label": "Court" },
            { "value": "shipping", "label": "Versand (LKW)" },
            { "value": "collect", "label": "Click & Collect" },
            { "value": "payment", "label": "Zahlung (Karte)" },
            { "value": "return", "label": "Rueckgabe" },
            { "value": "expert", "label": "Fachkompetenz (Stern)" },
            { "value": "secure", "label": "Sicher (Schild)" },
            { "value": "check", "label": "Haken" }
          ],
          "default": "advice"
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Eigenes Icon (ersetzt das obige)" },
        { "type": "text", "id": "label", "label": "Label", "default": "Persoenliche Beratung" },
        { "type": "text", "id": "sub", "label": "Untertext (optional)" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust-Leiste",
      "blocks": [
        { "type": "item", "settings": { "icon": "advice", "label": "Persoenliche Beratung" } },
        { "type": "item", "settings": { "icon": "store", "label": "Eigene Stores" } },
        { "type": "item", "settings": { "icon": "court", "label": "Eigene Courts" } },
        { "type": "item", "settings": { "icon": "shipping", "label": "Schneller Versand" } },
        { "type": "item", "settings": { "icon": "collect", "label": "Click & Collect" } },
        { "type": "item", "settings": { "icon": "secure", "label": "Sichere Zahlung" } }
      ]
    }
  ]
}
{% endschema %}
