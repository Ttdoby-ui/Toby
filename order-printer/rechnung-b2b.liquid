{% comment %}
  ============================================================================
  Futurespin – B2B-RECHNUNG für Order Printer (Netto-Ausweis)
  ============================================================================
  Für Geschäftskunden (Tags B2B1 / B2B2 / B2B3). Positionen werden netto
  ausgewiesen, MwSt nach Steuersätzen aufgeschlüsselt (§14 UStG).

  Annahmen (entsprechend Shop-Konfiguration):
  - "Preise inkl. MwSt" (taxesIncluded = true) -> gespeicherte Beträge sind brutto.
  - Versand unbesteuert (taxShipping = false) -> Versand netto = brutto.

  VOR DEM EINSATZ AUSFÜLLEN:
  - USt-IdNr. (Platzhalter DE000000000 ersetzen)
  - Absenderadresse: Einstellungen -> Geschäftsdaten
  ============================================================================
{% endcomment %}
<div>
<div class="columns">
   <div>
      <img src="https://cdn.shopify.com/s/files/1/0780/9607/3052/files/futurespin-logo-clean.jpg?v=1781696186"
           alt="futurespin" style="height: 32px; width: auto; display: block; background: #fff;" />
   </div>
   <div>
      {% assign invoice_number = order.order_number | plus: 1000 %}
      <p style="text-align: right; margin: 0;">
         <strong>Rechnungsnummer: R{{ invoice_number }}</strong><br />
         {{ "invoice_template.order_label" | t }} {{ order.order_name }}<br />
         {% if order.po_number %}{{ "invoice_template.po_number_label" | t }} {{ order.po_number }}<br />{% endif %}
         Rechnungsdatum: {{ order.created_at | date: "%d.%m.%Y" }}<br />
         Liefer-/Leistungsdatum: {{ order.created_at | date: "%d.%m.%Y" }}
      </p>
   </div>
</div>

<h1>Rechnung</h1>

<div class="columns" style="margin-top: 1.5em;">
   <div class="address">
      <strong>{{ "invoice_template.from_label" | t }}</strong><br/>
      {{ shop.name }}<br/>
      {{ shop.address | format_address }}
      {% if shop.phone %}{{ shop.phone }}<br/>{% endif %}
      {% if shop.email %}{{ shop.email }}<br/>{% endif %}
      <strong>USt-IdNr.: DE000000000</strong>
   </div>
   {% if order.billing_address %}
   <div class="address">
      <strong>{{ "invoice_template.bill_to_label" | t }}</strong>
      {{ order.billing_address | format_address }}
   </div>
   {% endif %}
   {% if order.shipping_address %}
   <div class="address">
      <strong>{{ "invoice_template.ship_to_label" | t }}</strong>
      {{ order.shipping_address | format_address }}
      {% if order.shipping_address.phone %}{{ order.shipping_address.phone }}{% endif %}
   </div>
   {% endif %}
</div>

<p class="subduedText" style="margin: .75em 0 0;">Alle Positionen verstehen sich netto zzgl. der gesetzlichen Umsatzsteuer.</p>

<hr />

<h2>{{ "invoice_template.order_details_title" | t }}</h2>
<table class="table-tabular" style="margin: 1em 0 0 0;">
   <thead>
      <tr>
         <th>{{ "invoice_template.column_headings.quantity" | t }}</th>
         <th>{{ "invoice_template.column_headings.item" | t }}</th>
         <th style="text-align: right;">Einzelpreis netto</th>
         <th style="text-align: right;">MwSt</th>
         <th style="text-align: right;">Gesamt netto</th>
      </tr>
   </thead>
   <tbody>
      {% for line_item in order.line_items %}
         {% assign rate = 0 %}
         {% for tl in line_item.tax_lines %}{% assign rate = tl.rate %}{% endfor %}
         {% assign rate_pct = rate | times: 100 | round %}
         {% assign divisor = rate_pct | plus: 100 %}
         {% assign unit_net = line_item.final_price | times: 100 | divided_by: divisor %}
         {% assign line_net = line_item.final_line_price | times: 100 | divided_by: divisor %}
      <tr>
         <td>{{ line_item.quantity }}</td>
         <td>{{ line_item.title }}
            {% if line_item.variant_title %}<br /><span class="subduedText">{{ line_item.variant_title }}</span>{% endif %}
            {% if line_item.sku != blank %}<br /><span class="subduedText">SKU: {{ line_item.sku }}</span>{% endif %}
            {% if line_item.line_level_discount_allocations.size > 0 %}
            <span class="subduedText">
            {% for discount_allocation in line_item.line_level_discount_allocations %}
            <br>{{ discount_allocation.discount_application.title }}
            {% endfor %}
            </span>
            {% endif %}
         </td>
         <td style="text-align: right;">
            {% if line_item.original_price != line_item.final_price %}
               {% assign unit_net_orig = line_item.original_price | times: 100 | divided_by: divisor %}
               <span class="subduedText"><s>{{ unit_net_orig | money }}</s></span><br />
            {% endif %}
            {{ unit_net | money }}
         </td>
         <td style="text-align: right;">{{ rate_pct }} %</td>
         <td style="text-align: right;">{{ line_net | money }}</td>
      </tr>
      {% endfor %}

      {% comment %} Netto-Warenwert = Gesamt(brutto) - MwSt - Versand (Versand unbesteuert) {% endcomment %}
      {% assign goods_net = order.total_price | minus: order.tax_price | minus: order.shipping_price %}

      <tr>
         <td colspan="4" style="text-align: right;">Zwischensumme (netto)</td>
         <td style="text-align: right;">{{ goods_net | money }}</td>
      </tr>

      {% if order.shipping_address %}
      <tr>
         <td colspan="4" style="text-align: right;">{{ "invoice_template.shipping_label" | t }} (netto)</td>
         <td style="text-align: right;">{{ order.shipping_price | money }}</td>
      </tr>
      {% endif %}

      {% comment %} MwSt aufgeschlüsselt nach Steuersätzen {% endcomment %}
      {% for tax_line in order.tax_lines %}
         {% assign rate_pct = tax_line.rate | times: 100 | round %}
         {% assign net_for_rate = tax_line.price | times: 100 | divided_by: rate_pct %}
      <tr>
         <td colspan="4" style="text-align: right;">
            <span class="subduedText">Netto zu {{ rate_pct }} %: {{ net_for_rate | money }}</span><br />
            zzgl. {{ rate_pct }} % MwSt
         </td>
         <td style="text-align: right;">{{ tax_line.price | money }}</td>
      </tr>
      {% endfor %}

      <tr>
         <td colspan="4" style="text-align: right;"><strong>{{ "invoice_template.total_label" | t }} (brutto)</strong></td>
         <td style="text-align: right;"><strong>{{ order.total_price | money }}</strong></td>
      </tr>

      {% if order.net_payment != order.total_net_amount %}
      <tr>
         <td colspan="4" style="text-align: right;">{{ "invoice_template.total_paid_label" | t }}</td>
         <td style="text-align: right;">{{ order.net_payment | money }}</td>
      </tr>
      {% endif %}

      {% if order.total_refunded_amount > 0 %}
      <tr>
         <td colspan="4" style="text-align: right;">{{ "invoice_template.total_refunded_label" | t }}</td>
         <td style="text-align: right;">-{{ order.total_refunded_amount | money }}</td>
      </tr>
      {% endif %}

      {% if order.net_payment != order.total_net_amount %}
      <tr>
         <td colspan="4" style="text-align: right;"><strong>{{ "invoice_template.outstanding_amount_label" | t }}</strong></td>
         <td style="text-align: right;"><strong>{{ order.total_price | minus: order.net_payment | money }}</strong></td>
      </tr>
      {% endif %}
   </tbody>
</table>

{% if transactions.size > 1 %}
<h2>{{ "invoice_template.transaction_details_title" | t }}</h2>
<table class="table-tabular" style="margin: 0 0 1.5em 0;">
   <thead>
      <tr>
         <th>{{ "invoice_template.transaction_headings.type" | t }}</th>
         <th>{{ "invoice_template.transaction_headings.amount" | t }}</th>
         <th>{{ "invoice_template.transaction_headings.kind" | t }}</th>
         <th>{{ "invoice_template.transaction_headings.status" | t }}</th>
      </tr>
   </thead>
   <tbody>
      {% for transaction in transactions %}
      <tr>
         <td>{{ transaction.gateway | payment_method }}</td>
         <td>{{ transaction.amount | money }}</td>
         <td>{{ transaction.kind }}</td>
         <td>{{ transaction.status }}</td>
      </tr>
      {% endfor %}
   </tbody>
</table>
{% endif %}

<h2>Zahlungsinformationen</h2>
<table class="table-tabular" style="margin: 0 0 1.5em 0;">
   <thead>
      <tr>
         <th>Zahlungsart</th>
         <th>Datum</th>
         <th style="text-align: right;">Betrag</th>
         <th>Referenz / Zuordnung</th>
      </tr>
   </thead>
   <tbody>
      {% for transaction in order.transactions %}
         {% if transaction.status == 'success' and transaction.kind != 'authorization' %}
         <tr>
            <td>
               {% if transaction.gateway == 'shopify_payments' %}
                  Shopify Payments
                  {% if transaction.payment_details.credit_card_company %}
                     <br /><span class="subduedText">{{ transaction.payment_details.credit_card_company }}
                     {{ transaction.payment_details.credit_card_number }}</span>
                  {% endif %}
               {% else %}
                  {{ transaction.gateway | replace: '_', ' ' | capitalize }}
               {% endif %}
            </td>
            <td>{{ transaction.created_at | date: "%d.%m.%Y" }}</td>
            <td style="text-align: right;">{{ transaction.amount | money }}</td>
            <td style="font-family: monospace; font-size: .85em;">
               {% if transaction.gateway == 'shopify_payments' %}
                  Charge: {{ transaction.authorization }}<br />
                  Txn-ID: {{ transaction.id }}
               {% else %}
                  {{ transaction.authorization }}
               {% endif %}
            </td>
         </tr>
         {% endif %}
      {% endfor %}
   </tbody>
</table>

{% if order.note %}
<h2>{{ "invoice_template.note_title" | t }}</h2>
<p>{{ order.note }}</p>
{% endif %}

<p class="subduedText" style="margin-bottom: 0;">Das Liefer-/Leistungsdatum entspricht dem Rechnungsdatum, sofern nicht anders angegeben.</p>
<p style="margin-bottom: 0;">{{ "invoice_template.email_footer" | t: email: shop.email }}</p>
</div>
