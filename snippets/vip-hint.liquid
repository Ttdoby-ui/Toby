{%- comment -%}
  snippets/vip-hint.liquid
  Grafischer VIP-Hinweis auf jeder PDP: "15% VIP-Rabatt" + Registrierungs-CTA.
  Öffentlich wird bewusst NUR die 15%-Stufe beworben (VIP2/25% + VIP3/30% nicht).
  Wird für bereits eingeloggte VIP-Kunden (Tags VIP1/2/3) ausgeblendet.
  Eingebunden in blocks/buy-buttons.liquid direkt unter dem Kaufen-Button.
  Markenfarben: Blau #486A8F, VIP-Gold #C19A3E. Self-contained (scoped CSS .fsvip-*).
{%- endcomment -%}

{%- assign fsvip_is_vip = false -%}
{%- if customer.tags contains 'VIP1' or customer.tags contains 'VIP2' or customer.tags contains 'VIP3' -%}
  {%- assign fsvip_is_vip = true -%}
{%- endif -%}

{%- unless fsvip_is_vip -%}
<aside class="fsvip-hint" aria-label="VIP-Rabatt Vorteil">
  <div class="fsvip-hint__badge" aria-hidden="true">
    <span class="fsvip-hint__pct">15<span class="fsvip-hint__pctsign">%</span></span>
    <span class="fsvip-hint__badge-label">VIP</span>
  </div>
  <div class="fsvip-hint__body">
    <p class="fsvip-hint__title">
      <svg class="fsvip-hint__crown" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <path fill="currentColor" d="M3 7l4.5 4L12 4l4.5 7L21 7l-1.6 11H4.6L3 7z"/>
      </svg>
      15&nbsp;% VIP-Rabatt sichern
    </p>
    <p class="fsvip-hint__text">Kostenlos registrieren und dauerhaft <strong>15&nbsp;%</strong> auf (fast) das gesamte Sortiment sparen.</p>
    <div class="fsvip-hint__actions">
      <a class="fsvip-hint__btn" href="/account/login">Jetzt kostenlos registrieren</a>
      <a class="fsvip-hint__link" href="/pages/rabattbestimmungen">Rabatt-Details</a>
    </div>
  </div>
</aside>

{%- style -%}
.fsvip-hint{
  --fsvip-blue:#486A8F; --fsvip-gold:#C19A3E;
  display:flex; align-items:center; gap:.9rem;
  margin:1rem 0 .25rem; padding:.85rem 1rem;
  border:1px solid rgba(72,106,143,.25); border-radius:12px;
  background:linear-gradient(135deg,rgba(72,106,143,.07),rgba(193,154,62,.09));
  box-sizing:border-box;
}
.fsvip-hint__badge{
  flex:0 0 auto; width:60px; height:60px; border-radius:50%;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  color:#fff; background:radial-gradient(circle at 30% 25%,#d8b45a,#C19A3E 60%,#a67f2c);
  box-shadow:0 2px 6px rgba(166,127,44,.35); line-height:1;
}
.fsvip-hint__pct{ font-size:1.35rem; font-weight:800; letter-spacing:-.02em; }
.fsvip-hint__pctsign{ font-size:.72em; font-weight:700; }
.fsvip-hint__badge-label{ font-size:.6rem; font-weight:700; letter-spacing:.14em; margin-top:.1rem; }
.fsvip-hint__body{ min-width:0; }
.fsvip-hint__title{
  margin:0 0 .15rem; font-size:1rem; font-weight:700; color:var(--fsvip-blue);
  display:flex; align-items:center; gap:.35rem; line-height:1.25;
}
.fsvip-hint__crown{ color:var(--fsvip-gold); flex:0 0 auto; }
.fsvip-hint__text{ margin:0 0 .5rem; font-size:.85rem; line-height:1.35; color:#3a3a3a; }
.fsvip-hint__text strong{ color:var(--fsvip-blue); }
.fsvip-hint__actions{ display:flex; align-items:center; gap:.75rem; flex-wrap:wrap; }
.fsvip-hint__btn{
  display:inline-block; background:var(--fsvip-blue); color:#fff !important;
  font-size:.82rem; font-weight:600; text-decoration:none;
  padding:.5rem .9rem; border-radius:8px; transition:background .15s;
}
.fsvip-hint__btn:hover{ background:#3b5877; }
.fsvip-hint__link{ font-size:.8rem; color:var(--fsvip-blue); text-decoration:underline; text-underline-offset:2px; }
.fsvip-hint__link:hover{ color:var(--fsvip-gold); }
@media (max-width:480px){
  .fsvip-hint{ gap:.7rem; padding:.75rem .8rem; }
  .fsvip-hint__badge{ width:52px; height:52px; }
  .fsvip-hint__pct{ font-size:1.15rem; }
  .fsvip-hint__title{ font-size:.92rem; }
}
{%- endstyle -%}
{%- endunless -%}
