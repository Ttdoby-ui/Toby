{%- comment -%}
  Klebe-Service Snippet für Belag-Produkte (futurespin).
  Zeigt "Belag kleben lassen (+2,50 €)" nur bei Produkten mit Tag "Belag".
  Klebe-Service Variant ID: 57809405641052

  Trigger: theme-eigenes 'cart:update' Event (CartAddEvent aus events.js),
  das product-form-component nach erfolgreichem Cart-Add dispatcht.
{%- endcomment -%}

{% stylesheet %}
  .klebe-service {
    display: flex;
    align-items: center;
    width: 100%;
    padding-block: var(--padding-sm, 0.5rem) 0;
  }

  .klebe-service__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-family: var(--font-body--family, inherit);
    font-size: var(--font-size--sm, 0.875rem);
    line-height: 1.4;
    color: var(--color-foreground);
  }

  .klebe-service__checkbox {
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.125rem;
    cursor: pointer;
    accent-color: var(--color-primary, currentColor);
    border-radius: 2px;
  }

  .klebe-service__price {
    color: var(--color-foreground-secondary, color-mix(in srgb, var(--color-foreground) 60%, transparent));
    font-size: var(--font-size--xs, 0.75rem);
    white-space: nowrap;
    margin-inline-start: 0.125rem;
  }
{% endstylesheet %}

{% if product.tags contains 'Belag' %}

<div class="klebe-service" data-klebe-block-id="{{ block.id }}">
  <label class="klebe-service__label" for="klebe-service-{{ block.id }}">
    <input
      type="checkbox"
      id="klebe-service-{{ block.id }}"
      class="klebe-service__checkbox"
    >
    <span class="klebe-service__text">
      Belag kleben lassen
      <span class="klebe-service__price">(+2,50&nbsp;€)</span>
    </span>
  </label>
</div>

<script>
(function () {
  'use strict';

  var KLEBE_VARIANT_ID = 57809405641052;
  var blockId = '{{ block.id | escape }}';
  var isAdding = false;

  function init() {
    // buy-buttons-block dieses spezifischen Blocks finden
    var wrapper = document.querySelector('.buy-buttons-block--' + blockId);
    if (!wrapper) return;

    var productForm = wrapper.querySelector('product-form-component');
    if (!productForm) return;

    // Das theme-eigene 'cart:update' Event abfangen.
    // CartAddEvent (events.js) nutzt ThemeEvents.cartUpdate = 'cart:update'
    // und wird von product-form-component nach erfolgreichem Fetch dispatcht.
    productForm.addEventListener('cart:update', function (event) {
      var detail = event.detail;
      if (!detail || !detail.data) return;

      // Nur auf Erfolge reagieren (kein Fehler, Quelle ist das Produktformular)
      if (detail.data.didError === true) return;
      if (detail.data.source !== 'product-form-component') return;

      var checkbox = document.getElementById('klebe-service-' + blockId);
      if (checkbox && checkbox.checked && !isAdding) {
        addKlebeService();
      }
    });
  }

  function addKlebeService() {
    isAdding = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        items: [{ id: KLEBE_VARIANT_ID, quantity: 1 }]
      })
    })
      .then(function (response) {
        if (!response.ok) {
          return response.json().then(function (data) {
            throw new Error(data.description || 'Cart-Add fehlgeschlagen');
          });
        }
        return response.json();
      })
      .then(function () {
        // Cart-Icon aktualisieren: 'cart:update' auf document dispatchen,
        // damit der Warenkorb-Zähler im Header neu geladen wird.
        document.dispatchEvent(
          new CustomEvent('cart:update', {
            bubbles: true,
            detail: { data: { source: 'klebe-service' } }
          })
        );
        isAdding = false;
      })
      .catch(function (err) {
        console.warn('[Klebe-Service] Fehler beim Hinzufügen:', err);
        isAdding = false;
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    requestAnimationFrame(init);
  }
})();
</script>

{% endif %}
