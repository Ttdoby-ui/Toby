

{%- liquid
  assign variant = closest.product.selected_or_first_available_variant
  if variant.inventory_management == 'shopify'
    assign inventory_managed = true
  endif
  assign inventory_quantity = variant.inventory_quantity
  assign inventory_policy = variant.inventory_policy

  if inventory_managed
    if inventory_quantity > 0
      assign status = 'in_stock'
    else
      if inventory_policy == 'continue'
        assign status = 'low'
      else
        assign status = 'out_of_stock'
      endif
    endif
  else
    if closest.product.selected_or_first_available_variant != null
      assign status = 'in_stock'
    else
      assign status = 'out_of_stock'
    endif
  endif
-%}

<product-inventory
  class="product-inventory spacing-style{% if block.settings.type_preset != '' %} {{ block.settings.type_preset }}{% endif %}"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
  data-product-id="{{ product.id }}"
>
  <span class="product-inventory__status">
    <span class="svg-wrapper product-inventory__icon product-inventory__icon--{{ status }}">
      {{ 'icon-inventory.svg' | inline_asset_content }}
    </span>
    <span
      class="product-inventory__text product-inventory__text--{{ status }}"
      id="Inventory-{{ section.id }}"
      role="status"
      aria-label="{{ 'accessibility.inventory_status' | t }}"
    >
      {%- if status == 'in_stock' -%}
        {%- if inventory_managed -%}
          {%- if inventory_quantity > 9 -%}
            Bestand >9
          {%- else -%}
            Bestand {{ inventory_quantity }}
          {%- endif -%}
        {%- else -%}
          {{- 'content.inventory_in_stock' | t -}}
        {%- endif -%}
        &nbsp;&middot;&nbsp;in 1-3 Werktagen bei dir
      {%- elsif status == 'low' -%}
        Bestand 0&nbsp;&middot;&nbsp;in 3-5 Werktagen bei dir
      {%- else -%}
        {{- 'products.product.sold_out' | t -}}
      {%- endif -%}
    </span>
  </span>
</product-inventory>

{% stylesheet %}
  @keyframes inventory-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.4);
      opacity: 0.6;
    }
  }

  .product-inventory__status {
    display: flex;
    align-items: center;
    gap: var(--padding-xs);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
  }

  .product-inventory__icon,
  .product-inventory__icon svg {
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
    flex-shrink: 0;
  }

  .product-inventory__icon circle:first-of-type {
    opacity: 0.3;
  }

  .product-inventory__icon--in_stock {
    color: var(--color-instock, #1a7f37);
    animation: inventory-pulse 2s ease-in-out infinite;
  }

  .product-inventory__icon--low {
    color: var(--color-lowstock, #b25e09);
    animation: inventory-pulse 2s ease-in-out infinite;
  }

  .product-inventory__icon--out_of_stock {
    color: var(--color-outofstock, #c0152f);
  }

  .product-inventory__text--in_stock {
    color: var(--color-instock, #1a7f37);
  }

  .product-inventory__text--low {
    color: var(--color-lowstock, #b25e09);
  }

  .product-inventory__text--out_of_stock {
    color: var(--color-outofstock, #c0152f);
  }
{% endstylesheet %}

