{%- comment -%}
  Mobile Kategorie-Navigation (Futurespin)
  Horizontal scrollbare Kategorie-Leiste unter dem Header — NUR auf Smartphones (< 750px).
  Textlinks nebeneinander, jeweils mit senkrechtem Trennstrich; aktuelle Kategorie
  in Markenblau hervorgehoben. Speist sich aus einem wählbaren Menü (Default: Hauptmenü).
  Ein Menüpunkt, dessen Titel in %…% gesetzt ist (z. B. %SALE%), wird rot dargestellt
  und ohne die %-Marker ausgegeben.
  Darunter ein eigener, von Anfang an sichtbarer blauer Scroll-Indikator (zeigt auch
  die Scroll-Position) — native Scrollbars sind mobil nicht zuverlässig dauerhaft sichtbar.
  Ziel: schneller Sprung in Beläge/Hölzer/Marken ohne den Hamburger zu öffnen.
  Auf Desktop ausgeblendet (dort gibt es die Hauptnav).
{%- endcomment -%}

{%- assign chips_menu = section.settings.menu -%}
{%- if linklists[chips_menu] != blank and linklists[chips_menu].links.size > 0 -%}
<nav
  class="fs-chips color-{{ section.settings.color_scheme }}{% if section.settings.show_on_desktop %} fs-chips--all{% endif %}"
  aria-label="Kategorien"
>
  <ul class="fs-chips__track" role="list">
    {%- if section.settings.show_home -%}
      <li class="fs-chips__item">
        <a href="{{ routes.root_url }}" class="fs-chip{% if request.path == routes.root_url %} fs-chip--active{% endif %}">
          {{ section.settings.home_label | default: 'Start' }}
        </a>
      </li>
    {%- endif -%}
    {%- for link in linklists[chips_menu].links -%}
      {%- liquid
        assign chip_label = link.title
        assign chip_sale = false
        if link.title contains '%'
          assign chip_sale = true
          assign chip_label = link.title | remove: '%' | strip
        endif
      -%}
      <li class="fs-chips__item">
        <a
          href="{{ link.url }}"
          class="fs-chip{% if chip_sale %} fs-chip--sale{% endif %}{% if link.active or link.child_active %} fs-chip--active{% endif %}"
          {% if link.active %}aria-current="page"{% endif %}
        >
          {{ chip_label | escape }}
        </a>
      </li>
    {%- endfor -%}
  </ul>
  <div class="fs-chips__scroll" aria-hidden="true">
    <span class="fs-chips__scroll-thumb"></span>
  </div>
</nav>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('.fs-chips__track');
    var bar = root.querySelector('.fs-chips__scroll');
    var thumb = root.querySelector('.fs-chips__scroll-thumb');
    if (!track || !bar || !thumb) return;

    function update() {
      var sw = track.scrollWidth;
      var cw = track.clientWidth;
      if (sw <= cw + 1) {
        bar.style.display = 'none';
        return;
      }
      bar.style.display = 'block';
      var widthPct = Math.max((cw / sw) * 100, 12);
      thumb.style.width = widthPct + '%';
      var maxScroll = sw - cw;
      var pos = maxScroll > 0 ? track.scrollLeft / maxScroll : 0;
      thumb.style.left = pos * (100 - widthPct) + '%';
    }

    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    window.addEventListener('load', update);
    update();
  })();
</script>
{%- endif -%}

{% stylesheet %}
  .fs-chips {
    display: none;
  }

  .fs-chips--all {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .fs-chips {
      display: block;
    }
  }

  /* Seite gegen horizontales Wegscrollen schützen (Chips/Compare-App etc.). */
  html { overflow-x: hidden; }
  @supports (overflow: clip) { html { overflow-x: clip; } }

  /* "Vergleichen"-App (cots) darf die Seite nicht breiter als den Bildschirm machen
     (sitzt als fixierte Leiste -> wird von html-overflow nicht erfasst). */
  [class*="cots"] { max-width: 100vw !important; box-sizing: border-box; }

  /* Chip-Leiste hart auf Bildschirmbreite begrenzen -> scrollt intern statt die Seite zu dehnen. */
  .fs-chips {
    max-width: 100vw;
    overflow: hidden;
  }

  .fs-chips__track {
    display: flex;
    gap: 0;
    margin: 0;
    padding: 0.5rem var(--page-margin, 16px) 0.4rem;
    list-style: none;
    max-width: 100vw;
    box-sizing: border-box;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
  }

  .fs-chips__track::-webkit-scrollbar {
    display: none;
  }

  .fs-chips__item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    scroll-snap-align: start;
  }

  .fs-chips__item + .fs-chips__item {
    border-inline-start: 1px solid var(--color-border, #d9d9d9);
  }

  .fs-chip {
    display: inline-block;
    padding: 0.2rem 0.85rem;
    color: var(--color-foreground, #333);
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .fs-chip--active {
    color: var(--fs-chip-active, #486A8F);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
  }

  /* SALE bleibt rot — auch wenn es die aktive Kategorie ist (steht nach --active). */
  .fs-chip--sale {
    color: var(--fs-chip-sale, #e02020);
    font-weight: 700;
  }

  /* Eigener, von Anfang an sichtbarer Scroll-Indikator in Futurespin-Blau. */
  .fs-chips__scroll {
    position: relative;
    height: 3px;
    margin: 0 var(--page-margin, 16px) 0.5rem;
    background: var(--color-border, #e3e3e3);
    border-radius: 999px;
  }

  .fs-chips__scroll-thumb {
    position: absolute;
    inset-block: 0;
    left: 0;
    width: 30%;
    background: var(--fs-chip-active, #486A8F);
    border-radius: 999px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mobile Kategorien",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Horizontal scrollbare Kategorie-Leiste unter dem Header — nur auf Smartphones. Textlinks mit Trennstrich und blauem Scroll-Indikator, schneller Sprung in die Hauptkategorien ohne Hamburger-Menü. Ein Menüpunkt in %…% (z. B. %SALE%) wird rot angezeigt. Am besten direkt unter dem Header (bzw. unter der mobilen Suchleiste) platzieren."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menü",
      "default": "main-menu",
      "info": "Die obersten Menüpunkte werden als Kategorien angezeigt. Für eine kürzere, kuratierte Liste ein eigenes Menü anlegen und hier wählen."
    },
    {
      "type": "checkbox",
      "id": "show_home",
      "label": "„Start\"-Eintrag voranstellen",
      "default": false
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Beschriftung Start-Eintrag",
      "default": "Start"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Auch auf Desktop anzeigen",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    }
  ],
  "presets": [
    { "name": "Mobile Kategorien" }
  ]
}
{% endschema %}
