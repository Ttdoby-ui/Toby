{%- comment -%}
  Rabatt-Banner (Futurespin) — verlinktes Banner-Bild statt selbstgebauter
  Grafik. Bild-URL + Link-Ziel über Section-Settings (Default: IMG-5657 /
  /pages/rabattbestimmungen). Responsiv (width:100%, height:auto),
  overflow-sicher. Ganz oben auf der Startseite, über dem Hero-Slider.
{%- endcomment -%}

<section class="rsb color-{{ section.settings.color_scheme }}">
  <div class="rsb__inner">
    {% if section.settings.image_url != blank %}
      {% if section.settings.link_url != blank %}
        <a href="{{ section.settings.link_url }}" class="rsb__link" aria-label="{{ section.settings.alt | default: 'Rabattbestimmungen' | escape }}">
          <img
            class="rsb__img"
            src="{{ section.settings.image_url }}"
            alt="{{ section.settings.alt | default: 'Unsere Rabatte' | escape }}"
            loading="lazy"
          >
        </a>
      {% else %}
        <img
          class="rsb__img"
          src="{{ section.settings.image_url }}"
          alt="{{ section.settings.alt | default: 'Unsere Rabatte' | escape }}"
          loading="lazy"
        >
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .rsb {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    padding: clamp(0.6rem, 2vw, 1.4rem) 0;
  }

  .rsb__inner {
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--page-margin, 16px);
  }

  .rsb__link {
    display: block;
  }

  .rsb__img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin-inline: auto;
    border-radius: 6px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Rabatt-Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "image_url",
      "label": "Bild-URL",
      "default": "https://cdn.shopify.com/s/files/1/0780/9607/3052/files/IMG-5657.png?v=1782921084"
    },
    {
      "type": "text",
      "id": "link_url",
      "label": "Link-Ziel (Pfad)",
      "default": "/pages/rabattbestimmungen"
    },
    {
      "type": "text",
      "id": "alt",
      "label": "Alt-Text (Barrierefreiheit)",
      "default": "Unsere Rabatte im Überblick"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    }
  ],
  "presets": [
    { "name": "Rabatt-Banner" }
  ]
}
{% endschema %}
