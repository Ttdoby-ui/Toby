    </div>
    <div class="konfig__grid" id="kg-kantenband">
      <div class="k-loading"><div class="k-spinner"></div></div>
    </div>
    <div class="konfig__footer">
      <button class="k-btn k-btn--back" data-target="2">{{ 'konfigurator.btn.back' | t }}</button>
      <button class="k-btn k-btn--next" id="k-next-3">{{ 'konfigurator.btn.next_kantenband' | t }}</button>
    </div>
  </div>

  <!-- Panel 4: Schlägerversiegelung -->
  <div class="konfig__panel is-hidden" id="kp-4">
    <p class="konfig__panel-title">{{ 'konfigurator.titles.versiegelung' | t }}<span class="k-optional">{{ 'konfigurator.optional' | t }}</span></p>
    <p style="font-size:0.9rem;color:var(--color-foreground-secondary,#666);margin-bottom:1.25rem;">
      {{ 'konfigurator.versiegelung.desc' | t }}
    </p>
    <div class="k-vers-grid">
      <button type="button" class="k-vers-opt" id="k-vers-ja">
        <span class="k-vers-opt__icon">🛡️</span>
        <span class="k-vers-opt__title">{{ 'konfigurator.versiegelung.yes' | t }}</span>
        <span class="k-vers-opt__price">+{{ section.settings.versiegelung_preis | default: '5.00' }}&nbsp;€</span>
      </button>
      <button type="button" class="k-vers-opt" id="k-vers-nein">
        <span class="k-vers-opt__icon">✕</span>
        <span class="k-vers-opt__title">{{ 'konfigurator.versiegelung.no' | t }}</span>
        <span class="k-vers-opt__price">{{ 'konfigurator.versiegelung.no_price' | t }}</span>
      </button>
    </div>
    <div class="konfig__footer">
      <button class="k-btn k-btn--back" data-target="3">{{ 'konfigurator.btn.back' | t }}</button>
      <button class="k-btn k-btn--next" id="k-next-4">{{ 'konfigurator.btn.next_versiegelung' | t }}</button>
    </div>
  </div>

  <!-- Panel 5: Zusammenfassung -->
  <div class="konfig__panel is-hidden" id="kp-5">
    <p class="konfig__panel-title">{{ 'konfigurator.titles.summary' | t }}</p>
    <div class="konfig__summary" id="k-summary"></div>
    <div class="k-hint is-hidden" id="k-black-warning">
      {{ 'konfigurator.black_warning_pre' | t }} <strong>{{ 'konfigurator.black_warning_bold' | t }}</strong> {{ 'konfigurator.black_warning_post' | t }}
    </div>
    <div class="konfig__total">
      <span>{{ 'konfigurator.total' | t }}</span>
      <span class="konfig__total-price" id="k-total">–</span>
    </div>
    <div class="konfig__footer">
      <button class="k-btn k-btn--back" data-target="4">{{ 'konfigurator.btn.back' | t }}</button>
      <button class="k-btn k-btn--atc" id="k-atc">{{ 'konfigurator.btn.atc' | t }}</button>
    </div>
  </div>
</div>

