<script>
(function () {
  'use strict';
  var KonfigT = window.KonfigT || {};

  /* ---- Config (set via section settings) ---- */
  var HANDLE_HOLZ      = {{ section.settings.collection_holz | default: 'holzer' | json }};
  var HANDLE_BELAG     = {{ section.settings.collection_belag | default: 'belage' | json }};
  var HANDLE_KANTENBAND= {{ section.settings.collection_kantenband | default: 'kantenbander' | json }};
  var KLEBE_ID           = {{ section.settings.klebe_variant_id | default: '57810488852828' }};
  var KLEBE_PRICE        = parseFloat('{{ section.settings.klebe_preis | default: "5.00" }}') || 5.00;
  var VERSIEGELUNG_ID    = '{{ section.settings.versiegelung_variant_id | default: "" }}';
  var VERSIEGELUNG_PRICE = parseFloat('{{ section.settings.versiegelung_preis | default: "5.00" }}') || 5.00;

  var COLOR_CSS = {
    'schwarz': '#111', 'black': '#111',
    'rot': '#cc1a1a', 'red': '#cc1a1a',
    'dunkelrot': '#8b0000',
    'grün': '#2a6e2a', 'green': '#2a6e2a',
    'blau': '#1a4db5', 'blue': '#1a4db5',
    'orange': '#e85c00',
    'gelb': '#c8a000', 'yellow': '#c8a000',
    'lila': '#7b2fbf', 'violet': '#7b2fbf', 'purple': '#7b2fbf',
    'weiß': '#ddd', 'weiss': '#ddd', 'white': '#ddd',
    'pink': '#d63384',
    'braun': '#7b4a2d', 'brown': '#7b4a2d',
  };

  /* VIP discount percentage (0 = not a VIP customer) */
  var VIP_DISCOUNT = {{ vip_discount | default: 0 }};

  /* ---- State ---- */
  var S = { holz: null, vorhand: null, rueckhand: null, kantenband: null, versiegelung: false };

  /* ---- Cache ---- */
  var _cache = {};

  /* ---- DOM shortcuts ---- */
  function ge(id) { return document.getElementById(id); }
  var panels   = [0,1,2,3,4,5].map(function(i){ return ge('kp-' + i); });
  var navBtns  = Array.from(document.querySelectorAll('.konfig__nav-btn'));
  var nxt      = { 0: ge('k-next-0'), 1: ge('k-next-1'), 2: ge('k-next-2'), 3: ge('k-next-3'), 4: ge('k-next-4') };
  var blackHint= ge('k-black-hint');
  var atcBtn   = ge('k-atc');

  /* ---- Wire navigation ---- */
  navBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { goTo(+btn.dataset.panel); });
  });
  document.querySelectorAll('.k-btn--back').forEach(function(b) {
    b.addEventListener('click', function() { goTo(+b.dataset.target); });
  });
  [0,1,2,3,4].forEach(function(i) {
    if (nxt[i]) nxt[i].addEventListener('click', function() { goTo(i + 1); });
  });
  // Versiegelung Ja/Nein
  var versJa   = ge('k-vers-ja');
  var versNein = ge('k-vers-nein');
  function pickVers(val) {
    S.versiegelung = val;
    if (versJa)   versJa.classList.toggle('is-selected',  val);
    if (versNein) versNein.classList.toggle('is-selected', !val);
    updateNavBtns();
    setTimeout(function() { goTo(5); }, 200);
  }
  if (versJa)   versJa.addEventListener('click',   function() { pickVers(true); });
  if (versNein) versNein.addEventListener('click',  function() { pickVers(false); });
  if (atcBtn) atcBtn.addEventListener('click', addToCart);

  /* ---- Init ---- */
  loadProducts(HANDLE_HOLZ).then(function(ps) { renderSimple(ge('kg-holz'), ps, 'holz'); });
  var _belagPromise = loadProducts(HANDLE_BELAG);   // single shared promise – reused below
  loadProducts(HANDLE_KANTENBAND);

  // Auto-select from KI-Berater recommendation stored in localStorage
  (function () {
    var recJson;
    try { recJson = localStorage.getItem('konfigBeraterRec'); } catch (e) {}
    if (!recJson) return;
    var rec;
    try { rec = JSON.parse(recJson); } catch (e) { return; }
    try { localStorage.removeItem('konfigBeraterRec'); } catch (e) {}

    function findProd(arr, title) {
      if (!title) return null;
      var t = title.toLowerCase().trim();
      for (var i = 0; i < arr.length; i++) {
        if (arr[i].title.toLowerCase().trim() === t) return arr[i];
      }
      for (var i = 0; i < arr.length; i++) {
        if (arr[i].title.toLowerCase().indexOf(t) !== -1) return arr[i];
      }
      return null;
    }

    Promise.all([loadProducts(HANDLE_HOLZ), loadProducts(HANDLE_BELAG)]).then(function (res) {
      var holzProd    = findProd(res[0], rec.holz);
      var vorhandProd = findProd(res[1], rec.vorhand);
      var rueckhandProd = findProd(res[1], rec.rueckhand);

      if (holzProd)     { S.holz     = { product: holzProd,     variant: holzProd.variants[0]     }; if (nxt[0]) nxt[0].disabled = false; }
      if (vorhandProd)  { S.vorhand  = { product: vorhandProd,  variant: vorhandProd.variants[0]  }; if (nxt[1]) nxt[1].disabled = false; }
      if (rueckhandProd){ S.rueckhand= { product: rueckhandProd,variant: rueckhandProd.variants[0]}; if (nxt[2]) nxt[2].disabled = false; }

      updateNavBtns();
      goTo(5);
    });
  })();

  // Pre-select from URL params when navigating from a product page
  (function () {
    var params      = new URLSearchParams(window.location.search);
    var prePos      = params.get('position');
    var preProdId   = params.get('product_id');
    var preHandle   = params.get('product_handle');
    var preVarId    = params.get('variant_id');
    if (!prePos || (!preProdId && !preHandle)) return;

    var targetStep = prePos === 'vorhand' ? 1 : prePos === 'rueckhand' ? 2 : prePos === 'holz' ? 1 : null;
    if (targetStep === null) return;

    function applyPreSelection(prod) {
      if (!prod) return;
      var vari = prod.variants[0];
      if (preVarId) {
        for (var j = 0; j < prod.variants.length; j++) {
          if (String(prod.variants[j].id) === preVarId) { vari = prod.variants[j]; break; }
        }
      }
      if (prePos === 'vorhand') {
        S.vorhand = { product: prod, variant: vari };
        if (nxt[1]) nxt[1].disabled = false;
      } else if (prePos === 'rueckhand') {
        S.rueckhand = { product: prod, variant: vari };
        if (nxt[2]) nxt[2].disabled = false;
      } else if (prePos === 'holz') {
        S.holz = { product: prod, variant: vari };
        if (nxt[0]) nxt[0].disabled = false;
      }
      updateNavBtns();
    }

    if (preHandle) {
      // Use .json endpoint — returns same image/price format as /products.json
      // (.js endpoint returns images as plain strings and prices in cents, incompatible)
      fetch('/products/' + encodeURIComponent(preHandle) + '.json')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          applyPreSelection(data && data.product ? data.product : null);
          goTo(targetStep);
        })
        .catch(function() { goTo(targetStep); });
    } else {
      // Fallback: search in tag-filtered cache by product ID
      _belagPromise.then(function(products) {
        var prod = null;
        for (var i = 0; i < products.length; i++) {
          if (String(products[i].id) === preProdId) { prod = products[i]; break; }
        }
        applyPreSelection(prod);
        goTo(targetStep);
      });
    }
  }());

  /* ---- Navigate ---- */
  function goTo(idx) {
    if (idx === 1) { renderBelagPanel(ge('kg-vorhand'), 'vorhand'); }
    if (idx === 2) {
      var vh = S.vorhand && isBlk(S.vorhand.variant);
      if (blackHint) blackHint.classList.toggle('is-hidden', !vh);
      if (vh && S.rueckhand && isBlk(S.rueckhand.variant)) {
        S.rueckhand = null; if (nxt[2]) nxt[2].disabled = true;
      }
      renderBelagPanel(ge('kg-rueckhand'), 'rueckhand');
    }
    if (idx === 3) { renderKantenbandPanel(); }
    if (idx === 4) { renderVersiegelungPanel(); }
    if (idx === 5) { renderSummary(); }

    panels.forEach(function(p, i) { if (p) p.classList.toggle('is-hidden', i !== idx); });
    updateNavBtns(idx);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ---- Update nav bar (active/done classes + thumbnails) ---- */
  var NAV_ICONS = ['🏓', '⚫', '🔴', '📏', '🛡️'];
  function updateNavBtns(activeIdx) {
    var stateMap = [S.holz, S.vorhand, S.rueckhand, S.kantenband, S.versiegelung !== undefined ? S.versiegelung : null];
    navBtns.forEach(function(b, i) {
      if (activeIdx !== undefined) {
        b.classList.toggle('is-active', i === activeIdx);
        b.classList.toggle('is-done', i < activeIdx);
      }
      // Remove any existing thumbnail/emoji
      var existImg   = b.querySelector('.k-nav-img');
      var existEmoji = b.querySelector('.k-nav-emoji');

      // Step 4 (Versiegelung) uses boolean, not a product
      if (i === 4) {
        if (S.versiegelung) {
          if (!existEmoji) {
            existEmoji = document.createElement('span');
            existEmoji.className = 'k-nav-emoji';
            b.insertBefore(existEmoji, b.firstChild);
          }
          existEmoji.textContent = '🛡️';
        } else {
          if (existEmoji) existEmoji.remove();
        }
        return;
      }

      var sel = stateMap[i];
      if (sel && sel.product && sel.product.images && sel.product.images[0]) {
        // Product image available → show thumbnail
        var src = sel.product.images[0].src.replace(/(\.[^.?]+)(\?.*)?$/, '_40x$1$2');
        if (existEmoji) existEmoji.remove();
        if (!existImg) {
          existImg = document.createElement('img');
          existImg.className = 'k-nav-img';
          existImg.alt = '';
          b.insertBefore(existImg, b.firstChild);
        }
        existImg.src = src;
      } else if (sel && sel.product) {
        // Product selected but no image → show emoji fallback
        if (existImg) existImg.remove();
        if (!existEmoji) {
          existEmoji = document.createElement('span');
          existEmoji.className = 'k-nav-emoji';
          b.insertBefore(existEmoji, b.firstChild);
        }
        existEmoji.textContent = NAV_ICONS[i] || '✓';
      } else {
        // Nothing selected → remove both
        if (existImg)   existImg.remove();
        if (existEmoji) existEmoji.remove();
      }
    });
  }

  /* ---- Load (paginated collection fetch) ---- */
  function loadProducts(handle) {
    if (_cache[handle] !== undefined) return Promise.resolve(_cache[handle]);
    function fetchPage(url, acc) {
      return fetch(url)
        .then(function(r) {
          var link = r.headers.get('Link') || '';
          return r.json().then(function(d) { return { products: d.products || [], link: link }; });
        })
        .then(function(res) {
          var all = acc.concat(res.products);
          var m = res.link.match(/<([^>]+)>;\s*rel="next"/);
          if (m && res.products.length === 250) return fetchPage(m[1], all);
          _cache[handle] = all;
          return all;
        });
    }
    return fetchPage('/collections/' + encodeURIComponent(handle) + '/products.json?limit=250', [])
      .catch(function() { _cache[handle] = []; return []; });
  }

  function spinner() { return '<div class="k-loading"><div class="k-spinner"></div></div>'; }

  /* ---- Render: simple grid (Holz / Kantenband, single- or multi-variant) ---- */
  function renderSimple(grid, products, type) {
    if (!grid) return;
    grid.innerHTML = '';
    if (!products.length) {
      grid.innerHTML = '<p class="k-msg">' + KonfigT.no_products + '<br><small>Kollektion <em>' + esc(type === 'holz' ? HANDLE_HOLZ : HANDLE_KANTENBAND) + '</em> ist leer oder existiert nicht.</small></p>';
      return;
    }
    products.forEach(function(p) {
      var card = buildCard(p, type);
      if (p.variants.length > 1) {
        addVarSelectors(card, p, type, false);
      }
      // Restore selection highlight when re-rendering
      if (type === 'holz'      && S.holz      && S.holz.product.id      === p.id) card.classList.add('is-selected');
      if (type === 'kantenband'&& S.kantenband && S.kantenband.product.id === p.id) card.classList.add('is-selected');
      grid.appendChild(card);
    });
  }

  /* ---- Render: Belag grid (multi-variant with selectors) ---- */
  function renderBelagPanel(grid, type) {
    if (!grid) return;

    // Pre-selection banner
    var bannerEl = ge('k-pre-sel-' + type);
    var current  = type === 'vorhand' ? S.vorhand : S.rueckhand;
    if (bannerEl) {
      if (current) {
        var bImg = current.product.images && current.product.images[0]
          ? current.product.images[0].src.replace(/(\.[^.?]+)(\?.*)?$/, '_120x$1$2')
          : '';
        var bVar = current.variant.title && current.variant.title !== 'Default Title'
          ? current.variant.title : '';
        bannerEl.innerHTML =
          (bImg
            ? '<img class="k-pre-sel__img" src="' + bImg + '" alt="">'
            : '<div class="k-pre-sel__icon">🏓</div>') +
          '<div class="k-pre-sel__info">' +
            '<div class="k-pre-sel__lbl">' + KonfigT.already_selected + '</div>' +
            '<div class="k-pre-sel__name">' + esc(current.product.title) + '</div>' +
            (bVar ? '<div class="k-pre-sel__var">' + esc(bVar) + '</div>' : '') +
          '</div>' +
          '<button class="k-pre-sel__clear" id="k-pre-sel-clear-' + type + '">' + KonfigT.change + '</button>';
        bannerEl.classList.remove('is-hidden');

        var clearBtn = ge('k-pre-sel-clear-' + type);
        if (clearBtn) clearBtn.onclick = function () {
          if (type === 'vorhand') { S.vorhand = null; if (nxt[1]) nxt[1].disabled = true; }
          else                   { S.rueckhand = null; if (nxt[2]) nxt[2].disabled = true; }
          bannerEl.classList.add('is-hidden');
          grid.querySelectorAll('.k-card').forEach(function(c) { c.classList.remove('is-selected'); });
        };
      } else {
        bannerEl.classList.add('is-hidden');
      }
    }

    grid.innerHTML = spinner();
    loadProducts(HANDLE_BELAG).then(function(products) {
      grid.innerHTML = '';
      if (!products.length) {
        grid.innerHTML = '<p class="k-msg">' + KonfigT.no_rubbers + '<br><small>Kollektion <em>' + esc(HANDLE_BELAG) + '</em> ist leer oder existiert nicht.</small></p>';
        return;
      }
      var vorhandIsBlack = S.vorhand && isBlk(S.vorhand.variant);
      products.forEach(function(p) {
        var card = buildCard(p, type);
        addVarSelectors(card, p, type, type === 'rueckhand' && vorhandIsBlack);
        grid.appendChild(card);
        // Restore selection highlight
        if (type === 'vorhand'   && S.vorhand   && S.vorhand.product.id   === p.id) card.classList.add('is-selected');
        if (type === 'rueckhand' && S.rueckhand && S.rueckhand.product.id === p.id) card.classList.add('is-selected');
      });
      // Re-apply search filter if user already typed something
      var si = ge('k-search-' + type);
      if (si && si.value) filterGrid(grid, si.value);
    });
  }

  /* ---- Render: Kantenband grid ---- */
  function renderKantenbandPanel() {
    var grid = ge('kg-kantenband');
    if (!grid) return;
    grid.innerHTML = spinner();
    loadProducts(HANDLE_KANTENBAND).then(function(products) {
      grid.innerHTML = '';
      if (!products.length) {
        grid.innerHTML = '<p class="k-msg">' + KonfigT.no_kantenband + '<br><small>Kollektion <em>' + esc(HANDLE_KANTENBAND) + '</em> ist leer oder existiert nicht.</small></p>';
        return;
      }
      products.forEach(function(p) {
        var card = buildCard(p, 'kantenband');
        if (p.variants.length > 1) {
          addVarSelectors(card, p, 'kantenband', false);
        } else {
          // Single-variant: add explicit Auswählen/Entfernen button
          var v0 = p.variants[0];
          var isPreSel = S.kantenband && S.kantenband.product.id === p.id;
          var btnWrap = document.createElement('div');
          btnWrap.className = 'k-vars';
          var pickBtn = document.createElement('button');
          pickBtn.type = 'button';
          pickBtn.className = 'k-pick-btn';
          pickBtn.textContent = isPreSel ? KonfigT.selected : KonfigT.select;
          pickBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            pickProduct('kantenband', p, v0, card);
            var nowSel = S.kantenband && S.kantenband.product.id === p.id;
            pickBtn.textContent = nowSel ? KonfigT.selected : KonfigT.select;
            updateNavBtns();
          });
          btnWrap.appendChild(pickBtn);
          card.appendChild(btnWrap);
        }
        if (S.kantenband && S.kantenband.product.id === p.id) card.classList.add('is-selected');
        grid.appendChild(card);
      });
      // Re-apply search filter if user already typed something
      var si = ge('k-search-kantenband');
      if (si && si.value) filterGrid(grid, si.value);
    });
  }

  /* ---- Build base card ---- */
  function buildCard(product, type) {
    var card = document.createElement('div');
    card.className = 'k-card';
    card.dataset.productId = product.id;
    card.dataset.type = type;

    var imgSrc = '';
    if (product.images && product.images[0]) {
      imgSrc = product.images[0].src.replace(/(\.[^.?]+)(\?.*)?$/, '_300x$1$2');
    }

    var v0 = product.variants[0];
    var _basePrice = parseFloat(v0.price);
    var _vipObj = applyVip(_basePrice, parseFloat(v0.compare_at_price) || 0, product.tags);
    var _saleInfo = (window.SaleBadges && window.SaleBadges[v0.id]) || null;
    var _prodInfo = (window.ProductBadges && window.ProductBadges[product.id]) || null;
    var _badgeEmoji = _saleInfo && _saleInfo.emoji ? _saleInfo.emoji + ' ' : '';
    var _badgeColor = (_saleInfo && _saleInfo.color) || (_prodInfo && _prodInfo.color) || '';
    var _badgeStyle = _badgeColor ? ' style="background:' + _badgeColor + ';border-color:' + _badgeColor + '"' : '';
    var _badgeHtml = _vipObj.badge === 'sale'
      ? '<span class="k-price-badge k-price-badge--sale"' + _badgeStyle + '>' + _badgeEmoji + KonfigT.badge_sale + '</span> '
      : _vipObj.badge === 'vip'
        ? '<span class="k-price-badge k-price-badge--vip">VIP</span> '
        : (_prodInfo && _prodInfo.text)
          ? '<span class="k-price-badge k-price-badge--custom"' + (_prodInfo.color ? ' style="background:' + _prodInfo.color + ';border-color:' + _prodInfo.color + '"' : '') + '>' + _prodInfo.text + '</span> '
          : '';
    var _priceHtml = _vipObj.original !== null
      ? _badgeHtml + KonfigT.price_from + ' ' + fmtPrice(_vipObj.price.toFixed(2)) + ' <s class="k-orig-price">' + fmtPrice(_vipObj.original.toFixed(2)) + '</s>'
      : _badgeHtml + KonfigT.price_from + ' ' + fmtPrice(v0.price);
    card.innerHTML =
      '<div class="k-card__img">' +
      (imgSrc ? '<img src="' + imgSrc + '" alt="' + esc(product.title) + '" loading="lazy">' : '<div class="k-card__img-empty">🏓</div>') +
      '</div>' +
      '<div class="k-card__body">' +
      '<div class="k-card__name">' + esc(product.title) + '</div>' +
      '<div class="k-card__price">' + _priceHtml + '</div>' +
      '</div>';

    // Single-variant: click card → select
    if (product.variants.length === 1) {
      card.classList.add('is-clickable');
      card.addEventListener('click', function() { pickProduct(type, product, v0, card); });
    }

    return card;
  }

  /* ---- Add variant selectors to card ---- */
  function addVarSelectors(card, product, type, blackForbidden) {
    var opts = product.options || [];
    var vars = product.variants || [];
    if (!opts.length || vars.length <= 1) return;

    var sel = {};

    var wrap = document.createElement('div');
    wrap.className = 'k-vars';

    opts.forEach(function(opt, oi) {
      var isColor = /farbe|color|colour|couleur/i.test(opt.name);
      var grp = document.createElement('div');
      var lbl = document.createElement('span');
      lbl.className = 'k-vars__lbl';
      lbl.textContent = opt.name;
      grp.appendChild(lbl);

      if (isColor) {
        var sw = document.createElement('div');
        sw.className = 'k-swatches';
        opt.values.forEach(function(val) {
          var blkVal = /schwarz|black/i.test(val);
          var blocked = blackForbidden && blkVal;
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'k-swatch' + (blocked ? ' is-blocked' : '');
          btn.style.background = COLOR_CSS[val.toLowerCase()] || '#aaa';
          btn.title = blocked ? KonfigT.black_blocked_title : val;
          btn.disabled = blocked;
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            sw.querySelectorAll('.k-swatch').forEach(function(x){ x.classList.remove('is-on'); });
            btn.classList.add('is-on');
            sel[oi] = val;
            tryMatch();
          });
          sw.appendChild(btn);
        });
        grp.appendChild(sw);
      } else {
        var pl = document.createElement('div');
        pl.className = 'k-pills';
        opt.values.forEach(function(val) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'k-pill';
          btn.textContent = val;
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            pl.querySelectorAll('.k-pill').forEach(function(x){ x.classList.remove('is-on'); });
            btn.classList.add('is-on');
            sel[oi] = val;
            tryMatch();
          });
          pl.appendChild(btn);
        });
        grp.appendChild(pl);
      }

      wrap.appendChild(grp);
    });

    var pickBtn = document.createElement('button');
    pickBtn.type = 'button';
    pickBtn.className = 'k-pick-btn is-hidden';
    pickBtn.textContent = KonfigT.select;
    wrap.appendChild(pickBtn);
    card.appendChild(wrap);

    function tryMatch() {
      if (Object.keys(sel).length < opts.length) return;
      var match = null;
      for (var i = 0; i < vars.length; i++) {
        var v = vars[i];
        var ok = opts.every(function(o, oi) { return v['option' + (oi+1)] === sel[oi]; });
        if (ok) { match = v; break; }
      }
      if (!match) { pickBtn.classList.add('is-hidden'); return; }

      if (blackForbidden && isBlk(match)) {
        pickBtn.textContent = KonfigT.black_taken;
        pickBtn.disabled = true;
        pickBtn.classList.remove('is-hidden');
        return;
      }
      if (!match.available) {
        pickBtn.textContent = KonfigT.not_available;
        pickBtn.disabled = true;
        pickBtn.classList.remove('is-hidden');
        return;
      }

      pickBtn.textContent = KonfigT.select;
      pickBtn.disabled = false;
      pickBtn.classList.remove('is-hidden');
      pickBtn.onclick = function() { pickProduct(type, product, match, card); };
    }
  }

  /* ---- Select a product/variant ---- */
  function pickProduct(type, product, variant, card) {
    // Deselect siblings
    var grid = card.closest('.konfig__grid');
    if (grid) grid.querySelectorAll('.k-card').forEach(function(c){ c.classList.remove('is-selected'); });
    card.classList.add('is-selected');

    if (type === 'holz') {
      S.holz = { product: product, variant: variant };
      if (nxt[0]) nxt[0].disabled = false;
      updateNavBtns();
      setTimeout(function() { goTo(1); }, 200);
    } else if (type === 'vorhand') {
      S.vorhand = { product: product, variant: variant };
      if (nxt[1]) nxt[1].disabled = false;
      updateNavBtns();
      setTimeout(function() { goTo(2); }, 200);
    } else if (type === 'rueckhand') {
      S.rueckhand = { product: product, variant: variant };
      if (nxt[2]) nxt[2].disabled = false;
      updateNavBtns();
      setTimeout(function() { goTo(3); }, 200);
    } else if (type === 'kantenband') {
      var prev = S.kantenband;
      var same = prev && prev.product.id === product.id && prev.variant.id === variant.id;
      if (same) {
        S.kantenband = null;
        card.classList.remove('is-selected');
      } else {
        S.kantenband = { product: product, variant: variant };
        updateNavBtns();
        setTimeout(function() { goTo(4); }, 200);
      }
    }
  }

  /* ---- Render versiegelung step ---- */
  function renderVersiegelungPanel() {
    if (versJa)   versJa.classList.toggle('is-selected',  S.versiegelung === true);
    if (versNein) versNein.classList.toggle('is-selected', S.versiegelung === false);
  }

  /* ---- Render summary ---- */
  function renderSummary() {
    var rows = [];
    var total = 0;

    function addRow(label, product, variant, icon) {
      var img = product.images && product.images[0]
        ? product.images[0].src.replace(/(\.[^.?]+)(\?.*)?$/, '_80x$1$2')
        : '';
      var name = product.title;
      if (variant.title && variant.title !== 'Default Title') name += ' – ' + variant.title;
      var price = parseFloat(variant.price);
      var vipObj = applyVip(price, parseFloat(variant.compare_at_price) || 0, product.tags);
      var displayPrice = vipObj.price;
      total += displayPrice;
      var _rowSaleInfo = (window.SaleBadges && window.SaleBadges[variant.id]) || null;
      var _rowProdInfo = (window.ProductBadges && window.ProductBadges[product.id]) || null;
      var _rowEmoji = _rowSaleInfo && _rowSaleInfo.emoji ? _rowSaleInfo.emoji + ' ' : '';
      var _rowColor = (_rowSaleInfo && _rowSaleInfo.color) || (_rowProdInfo && _rowProdInfo.color) || '';
      var _rowBadgeStyle = _rowColor ? ' style="background:' + _rowColor + ';border-color:' + _rowColor + '"' : '';
      var _rowBadge = vipObj.badge === 'sale'
        ? '<span class="k-price-badge k-price-badge--sale"' + _rowBadgeStyle + '>' + _rowEmoji + KonfigT.badge_sale + '</span> '
        : vipObj.badge === 'vip'
          ? '<span class="k-price-badge k-price-badge--vip">VIP</span> '
          : (_rowProdInfo && _rowProdInfo.text)
            ? '<span class="k-price-badge k-price-badge--custom"' + (_rowProdInfo.color ? ' style="background:' + _rowProdInfo.color + ';border-color:' + _rowProdInfo.color + '"' : '') + '>' + _rowProdInfo.text + '</span> '
            : '';
      var priceHtml = vipObj.original !== null
        ? _rowBadge + fmtPrice(displayPrice.toFixed(2)) + ' <s class="k-orig-price">' + fmtPrice(vipObj.original.toFixed(2)) + '</s>'
        : fmtPrice(price.toFixed(2));
      rows.push(
        '<div class="k-sum-row">' +
        (img ? '<img class="k-sum-row__img" src="' + img + '" alt="">' : '<div class="k-sum-row__icon">' + icon + '</div>') +
        '<div class="k-sum-row__info"><div class="k-sum-row__lbl">' + esc(label) + '</div><div class="k-sum-row__name">' + esc(name) + '</div></div>' +
        '<div class="k-sum-row__price">' + priceHtml + '</div>' +
        '</div>'
      );
    }

    if (S.holz) addRow(KonfigT.row_holz, S.holz.product, S.holz.variant, '🏓');
    if (S.vorhand) addRow(KonfigT.row_vorhand, S.vorhand.product, S.vorhand.variant, '⚫');
    if (S.rueckhand) addRow(KonfigT.row_rueckhand, S.rueckhand.product, S.rueckhand.variant, '🔴');
    total += KLEBE_PRICE;
    rows.push(
      '<div class="k-sum-row">' +
      '<div class="k-sum-row__icon">🔧</div>' +
      '<div class="k-sum-row__info"><div class="k-sum-row__lbl">' + KonfigT.klebeservice_auto + '</div><div class="k-sum-row__name">' + KonfigT.klebeservice_desc + '</div></div>' +
      '<div class="k-sum-row__price">' + fmtPrice(KLEBE_PRICE.toFixed(2)) + '</div>' +
      '</div>'
    );
    if (S.versiegelung && VERSIEGELUNG_ID) {
      total += VERSIEGELUNG_PRICE;
      rows.push(
        '<div class="k-sum-row">' +
        '<div class="k-sum-row__icon">🛡️</div>' +
        '<div class="k-sum-row__info"><div class="k-sum-row__lbl">' + KonfigT.versiegelung_label + '</div><div class="k-sum-row__name">' + KonfigT.versiegelung_desc + '</div></div>' +
        '<div class="k-sum-row__price">' + fmtPrice(VERSIEGELUNG_PRICE.toFixed(2)) + '</div>' +
        '</div>'
      );
    }
    if (S.kantenband) addRow(KonfigT.row_kantenband, S.kantenband.product, S.kantenband.variant, '📏');

    var sumEl = ge('k-summary');
    var totEl = ge('k-total');
    if (sumEl) sumEl.innerHTML = rows.join('');
    if (totEl) totEl.textContent = fmtPrice(total.toFixed(2));

    // Black rubber validation: at least one must be black
    var selectedRubbers = [S.vorhand, S.rueckhand].filter(Boolean);
    var hasBlack = selectedRubbers.some(function(r) { return isBlk(r.variant); });
    var needsBlack = selectedRubbers.length > 0 && !hasBlack;
    var warnEl = ge('k-black-warning');
    if (warnEl) warnEl.classList.toggle('is-hidden', !needsBlack);

    if (atcBtn) {
      atcBtn.disabled = needsBlack;
      atcBtn.textContent = KonfigT.atc;
      atcBtn.className = 'k-btn k-btn--atc';
    }
  }

  /* ---- Add to cart ---- */
  function addToCart() {
    // Validation: required steps
    if (!S.holz) {
      atcBtn.textContent = KonfigT.error_no_holz;
      atcBtn.classList.add('is-err');
      setTimeout(function() {
        atcBtn.textContent = KonfigT.atc;
        atcBtn.classList.remove('is-err');
      }, 3000);
      return;
    }
    if (!S.vorhand && !S.rueckhand) {
      atcBtn.textContent = KonfigT.error_no_belag;
      atcBtn.classList.add('is-err');
      setTimeout(function() {
        atcBtn.textContent = KonfigT.atc;
        atcBtn.classList.remove('is-err');
      }, 3000);
      return;
    }

    var items = [];
    if (S.holz) items.push({ id: S.holz.variant.id, quantity: 1 });
    if (S.vorhand) items.push({ id: S.vorhand.variant.id, quantity: 1, properties: { 'Position': 'Vorhand' } });
    if (S.rueckhand) items.push({ id: S.rueckhand.variant.id, quantity: 1, properties: { 'Position': 'Rückhand' } });
    if (S.kantenband) items.push({ id: S.kantenband.variant.id, quantity: 1 });
    // Klebeservice wird immer automatisch hinzugefügt
    items.push({ id: KLEBE_ID, quantity: 1, properties: { 'Service': 'Klebeservice' } });
    if (S.versiegelung && VERSIEGELUNG_ID) items.push({ id: +VERSIEGELUNG_ID, quantity: 1, properties: { 'Service': 'Schlägerversiegelung' } });

    // Failsafe: enforce black rubber rule
    var selectedRubbers = [S.vorhand, S.rueckhand].filter(Boolean);
    if (selectedRubbers.length > 0 && !selectedRubbers.some(function(r) { return isBlk(r.variant); })) return;

    atcBtn.disabled = true;
    atcBtn.textContent = KonfigT.adding;

    console.log('[Konfigurator] addToCart items:', JSON.stringify(items));
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items }),
    })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(d) {
          throw new Error(d.description || d.message || 'HTTP ' + r.status);
        });
        return r.json();
      })
      .then(function() {
        atcBtn.textContent = KonfigT.in_cart;
        atcBtn.classList.add('is-ok');
        setOrderNote();
        document.dispatchEvent(new CustomEvent('cart:update', {
          bubbles: true,
          detail: { data: { source: 'konfigurator' } },
        }));
      })
      .catch(function(err) {
        console.error('[Konfigurator] cart error:', err.message, '| items:', JSON.stringify(items));
        atcBtn.textContent = KonfigT.error_prefix + err.message;
        atcBtn.classList.add('is-err');
        atcBtn.disabled = false;
      });
  }

  /* ---- Packzettel-Notiz ---- */
  function setOrderNote() {
    function selName(sel) {
      if (!sel) return '–';
      var n = sel.product.title;
      if (sel.variant.title && sel.variant.title !== 'Default Title') n += ' (' + sel.variant.title + ')';
      return n;
    }

    var lines = [
      KonfigT.note_header,
      KonfigT.note_holz      + selName(S.holz),
      KonfigT.note_vorhand   + selName(S.vorhand),
      KonfigT.note_rueckhand + selName(S.rueckhand),
      KonfigT.note_kantenband + (S.kantenband ? selName(S.kantenband) : KonfigT.note_none),
      KonfigT.note_klebeservice + KonfigT.note_klebeservice_val,
      KonfigT.note_versiegelung + (S.versiegelung && VERSIEGELUNG_ID ? KonfigT.yes : KonfigT.no),
      KonfigT.note_footer,
    ];

    var attrs = {};
    attrs[KonfigT.attr_holz]          = selName(S.holz);
    attrs[KonfigT.attr_vorhand]       = selName(S.vorhand);
    attrs[KonfigT.attr_rueckhand]     = selName(S.rueckhand);
    attrs[KonfigT.attr_klebeservice]  = KonfigT.yes;
    if (S.kantenband) attrs[KonfigT.attr_kantenband] = selName(S.kantenband);
    if (S.versiegelung && VERSIEGELUNG_ID) attrs[KonfigT.attr_versiegelung] = KonfigT.yes;

    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ note: lines.join('\n'), attributes: attrs }),
    }).catch(function() {});
  }

  /* ---- Helpers ---- */
  function isBlk(variant) {
    return [variant.option1, variant.option2, variant.option3]
      .filter(Boolean)
      .some(function(v) { return /schwarz|black/i.test(v); });
  }

  function fmtPrice(p) {
    return parseFloat(p).toFixed(2).replace('.', KonfigT.decimal_sep || ',') + ' €';
  }

  function hasTag(tags, tag) {
    if (!tags) return false;
    return (',' + tags + ',').indexOf(',' + tag + ',') !== -1;
  }

  function applyVip(price, compareAtPrice, tags) {
    var isOnSale = compareAtPrice && compareAtPrice > price;
    if (VIP_DISCOUNT <= 0 || !hasTag(tags, 'for_vip')) {
      return { price: price, original: isOnSale ? compareAtPrice : null, badge: isOnSale ? 'sale' : '' };
    }
    var uvp = isOnSale ? compareAtPrice : price;
    var existingPct = isOnSale ? (uvp - price) / uvp * 100 : 0;
    if (VIP_DISCOUNT > existingPct) {
      return { price: uvp * (100 - VIP_DISCOUNT) / 100, original: uvp, badge: 'vip' };
    }
    return { price: price, original: isOnSale ? uvp : null, badge: isOnSale ? 'sale' : '' };
  }

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, function(c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#x27;' }[c];
    });
  }

  /* ---- Grid search filter ---- */
  function filterGrid(grid, term) {
    var q = term.trim().toLowerCase();
    grid.querySelectorAll('.k-card').forEach(function(card) {
      var name = (card.querySelector('.k-card__name') || {}).textContent || '';
      card.style.display = (!q || name.toLowerCase().indexOf(q) !== -1) ? '' : 'none';
    });
  }

  // Wire search inputs to their grids
  [
    { searchId: 'k-search-holz',       gridId: 'kg-holz' },
    { searchId: 'k-search-vorhand',    gridId: 'kg-vorhand' },
    { searchId: 'k-search-rueckhand',  gridId: 'kg-rueckhand' },
    { searchId: 'k-search-kantenband', gridId: 'kg-kantenband' },
  ].forEach(function(pair) {
    var inp = ge(pair.searchId);
    if (!inp) return;
    inp.addEventListener('input', function() {
      var grid = ge(pair.gridId);
      if (grid) filterGrid(grid, inp.value);
    });
  });
})();
</script>

