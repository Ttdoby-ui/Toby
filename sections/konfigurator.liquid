    </div>
  </div>

  <!-- Panel 3: Kantenband -->
  <div class="konfig__panel is-hidden" id="kp-3">
    <p class="konfig__panel-title">{{ 'konfigurator.titles.kantenband' | t }}<span class="k-optional">{{ 'konfigurator.optional' | t }}</span></p>
