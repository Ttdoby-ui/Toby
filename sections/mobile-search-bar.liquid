{%- comment -%}
  Prominente Suchleiste (Futurespin)
  Sichtbare, prominente Suchleiste unter dem Header — auf ALLEN Geräten.
  Öffnet die bestehende Predictive-Search-Modal (#search-modal) des Themes,
  inkl. Live-Vorschlägen.
  - Mobil (< 750px): vollbreit unter dem Header.
  - Desktop (>= 750px): oben zentral, breitenbegrenzt + das Header-Lupensymbol
    (.search-action) wird ausgeblendet, da die Leiste es ersetzt.
{%- endcomment -%}

<div class="fs-msearch color-{{ section.settings.color_scheme }}">
  <button
    type="button"
    class="fs-msearch__bar"
    on:click="#search-modal/showDialog"
    aria-label="{{ 'accessibility.open_search_modal' | t }}"
    aria-haspopup="dialog"
  >
    <span class="fs-msearch__icon svg-wrapper" aria-hidden="true">
      {{ 'icon-search.svg' | inline_asset_content }}
    </span>
    <span class="fs-msearch__placeholder">{{ section.settings.placeholder }}</span>
  </button>
</div>

{% stylesheet %}
  .fs-msearch {
    display: block;
    padding: 0.55rem var(--page-margin, 16px);
  }

  .fs-msearch__bar {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-border, #ddd);
    border-radius: var(--style-border-radius-inputs, 8px);
    background: var(--color-background, #fff);
    color: var(--color-foreground, #555);
    font: inherit;
    font-size: 0.95rem;
    line-height: 1.2;
    text-align: left;
    cursor: pointer;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .fs-msearch__bar:hover,
  .fs-msearch__bar:focus-visible {
    border-color: #486a8f;
    box-shadow: 0 0 0 1px rgba(72, 106, 143, 0.35);
    outline: none;
  }

  .fs-msearch__icon {
    display: inline-flex;
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
    opacity: 0.7;
  }

  .fs-msearch__icon svg {
    width: 100%;
    height: 100%;
  }

  .fs-msearch__placeholder {
    opacity: 0.7;
  }

  /* Desktop: prominent + oben zentral, Breite begrenzt */
  @media screen and (min-width: 750px) {
    .fs-msearch {
      padding: 0.7rem var(--page-margin, 16px);
    }

    .fs-msearch__bar {
      max-width: 640px;
      margin-inline: auto;
      padding: 0.85rem 1.15rem;
      font-size: 1rem;
    }

    .fs-msearch__icon {
      width: 1.2rem;
      height: 1.2rem;
    }

    /* Lupensymbol im Header entfernen — die prominente Leiste ersetzt es. */
    #header-group .search-action,
    .header .search-action {
      display: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Suchleiste",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Sichtbare, prominente Suchleiste unter dem Header — auf allen Geräten. Öffnet die normale Suche mit Live-Vorschlägen. Auf Desktop zentriert und ersetzt das Header-Lupensymbol. Am besten direkt unter dem Header platzieren."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Platzhalter-Text",
      "default": "Belag, Holz, Marke …"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    }
  ],
  "presets": [
    { "name": "Suchleiste" }
  ]
}
{% endschema %}
