{%- comment -%}
  Mobile Suchleiste (Futurespin)
  Sichtbare, prominente Suchleiste unter dem Header — NUR auf Smartphones (< 750px).
  Öffnet die bestehende Predictive-Search-Modal (#search-modal) des Themes,
  inkl. Live-Vorschlägen. Auf Desktop ausgeblendet (dort gibt es die Header-Suche).
{%- endcomment -%}

<div class="fs-msearch color-{{ section.settings.color_scheme }}">
  <button
    type="button"
    class="fs-msearch__bar"
    on:click="#search-modal/showDialog"
    aria-label="{{ 'accessibility.open_search_modal' | t }}"
  >
    <span class="fs-msearch__icon svg-wrapper" aria-hidden="true">
      {{ 'icon-search.svg' | inline_asset_content }}
    </span>
    <span class="fs-msearch__placeholder">{{ section.settings.placeholder }}</span>
  </button>
</div>

{% stylesheet %}
  .fs-msearch {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .fs-msearch {
      display: block;
      padding: 0.5rem var(--page-margin, 16px);
    }

    .fs-msearch__bar {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      width: 100%;
      padding: 0.7rem 0.9rem;
      border: 1px solid var(--color-border, #ddd);
      border-radius: var(--style-border-radius-inputs, 8px);
      background: var(--color-background, #fff);
      color: var(--color-foreground, #555);
      font: inherit;
      font-size: 0.95rem;
      line-height: 1.2;
      text-align: left;
      cursor: pointer;
    }

    .fs-msearch__icon {
      display: inline-flex;
      width: 1.1rem;
      height: 1.1rem;
      flex: 0 0 auto;
      opacity: 0.7;
    }

    .fs-msearch__icon svg {
      width: 100%;
      height: 100%;
    }

    .fs-msearch__placeholder {
      opacity: 0.7;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mobile Suchleiste",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Sichtbare Suchleiste unter dem Header — nur auf Smartphones. Öffnet die normale Suche mit Live-Vorschlägen. Am besten direkt unter dem Header platzieren."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Platzhalter-Text",
      "default": "Belag, Holz, Marke …"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    }
  ],
  "presets": [
    { "name": "Mobile Suchleiste" }
  ]
}
{% endschema %}
